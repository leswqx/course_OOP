<Application x:Class="MSM.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MSM.Converters"
             xmlns:vm="clr-namespace:MSM.ViewModels"
             xmlns:views="clr-namespace:MSM.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Начальная тема и язык -->
                <ResourceDictionary Source="Resources/Themes/LightTheme.xaml"/>
                <ResourceDictionary Source="Resources/Languages/lang.ru.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Глобальный стиль TextBox: undo/redo через Ctrl+Z/Ctrl+Y -->
            <Style TargetType="TextBox">
                <Setter Property="IsUndoEnabled" Value="True"/>
                <Setter Property="UndoLimit"     Value="100"/>
                <Setter Property="Background"    Value="{DynamicResource InputBrush}"/>
                <Setter Property="Foreground"    Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
                <Setter Property="CaretBrush"    Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="SelectionBrush" Value="{DynamicResource PrimaryBrush}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- Глобальный стиль PasswordBox -->
            <Style TargetType="PasswordBox">
                <Setter Property="Background"  Value="{DynamicResource InputBrush}"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="CaretBrush"  Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- Конвертеры -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:PriceToStringConverter x:Key="PriceToString"/>
            <converters:RatingToStarsConverter x:Key="RatingToStars"/>
            <converters:AppointmentStatusToStringConverter x:Key="AppointmentStatusToString"/>
            <converters:ByteArrayToImageConverter x:Key="ByteArrayToImage"/>

            <!-- DataTemplates: WPF автоматически подбирает нужный View по типу ViewModel -->
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <views:LoginView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PropertyListViewModel}">
                <views:PropertyListView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PropertyDetailViewModel}">
                <views:PropertyDetailView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <views:HomeView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
