<UserControl x:Class="MSM.Controls.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MSM.Converters"
             mc:Ignorable="d"
             Height="70">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Все TextBlock: зелёный на светлом хедере, белый в hero-режиме -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHeroMode}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Стрелки: без рамки, без ховера -->
        <Style x:Key="ArrowBtn" TargetType="Button">
            <Setter Property="Width"  Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Навигационные кнопки: без рамки, без ховера -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height"     Value="36"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Квадратные иконочные кнопки: без рамки, без ховера -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width"      Value="36"/>
            <Setter Property="Height"     Value="34"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Фон: сливается с фоном страницы; на главной — прозрачный поверх фото -->
    <Border>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsHeroMode}" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.10"/>
        </Border.Effect>

        <Grid Margin="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ══ ЛЕВАЯ: Лого + стрелки ══ -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Лого: зелёный на светлом фоне, белый в hero-режиме -->
                <Image Height="40" Width="260" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,0,14,0">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Source" Value="/Resources/Images/logo-green.png"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHeroMode}" Value="True">
                                    <Setter Property="Source" Value="/Resources/Images/logo-white.png"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- Стрелка ← (жирная) -->
                <Button Style="{StaticResource ArrowBtn}"
                        Command="{Binding GoBackNavCommand}"
                        IsEnabled="{Binding CanGoBack}"
                        ToolTip="Назад" Margin="0,0,4,0">
                    <TextBlock Text="←" FontSize="16" FontWeight="Bold"/>
                </Button>

                <!-- Стрелка → (жирная) -->
                <Button Style="{StaticResource ArrowBtn}"
                        Command="{Binding GoForwardNavCommand}"
                        IsEnabled="{Binding CanGoForward}"
                        ToolTip="Вперёд">
                    <TextBlock Text="→" FontSize="16" FontWeight="Bold"/>
                </Button>
            </StackPanel>

            <!-- ══ ЦЕНТР: Навигация ══ -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">

                <Button Style="{StaticResource NavBtn}"
                        Command="{Binding GoHomeCommand}"
                        Margin="0,0,6,0">
                    <TextBlock Text="{DynamicResource Nav.Home}" FontSize="16" FontWeight="SemiBold"/>
                </Button>

                <Button Style="{StaticResource NavBtn}"
                        Command="{Binding GoToCatalogCommand}"
                        Margin="0,0,6,0">
                    <TextBlock Text="{DynamicResource Nav.Catalog}" FontSize="16" FontWeight="SemiBold"/>
                </Button>

                <Button Style="{StaticResource NavBtn}"
                        Command="{Binding GoToAboutCommand}">
                    <TextBlock Text="{DynamicResource Nav.About}" FontSize="16" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>

            <!-- ══ ПРАВАЯ: Язык + Тема + разделитель + Избранное + Войти/Профиль ══ -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Язык -->
                <Button Style="{StaticResource IconBtn}"
                        Command="{Binding ToggleLanguageCommand}"
                        ToolTip="Язык / Language" Margin="0,0,6,0">
                    <TextBlock Text="{Binding LanguageIcon}" FontSize="12" FontWeight="SemiBold"/>
                </Button>

                <!-- Тема -->
                <Button Style="{StaticResource IconBtn}"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip="Тема / Theme" Margin="0,0,10,0">
                    <Grid Width="20" Height="20">
                        <!-- Луна — показывается в светлой теме (переключить в тёмную) -->
                        <Path Width="18" Height="18" Stretch="Uniform"
                              Data="M17.75,4.09L15.22,6.03L16.13,9.09L13.5,7.28L10.87,9.09L11.78,6.03L9.25,4.09L12.44,4L13.5,1L14.56,4L17.75,4.09M21.25,11L19.61,12.25L20.2,14.23L18.5,13.12L16.8,14.23L17.39,12.25L15.75,11L17.81,10.95L18.5,9L19.19,10.95L21.25,11M18.97,15.95C19.8,15.87 20.69,17.05 20.16,17.8C19.84,18.25 19.5,18.67 19.08,19.07C15.17,23 8.84,23 4.94,19.07C1.03,15.17 1.03,8.83 4.94,4.93C5.34,4.53 5.76,4.17 6.21,3.85C6.96,3.32 8.14,4.21 8.06,5.04C7.79,7.9 8.75,10.87 10.95,13.06C13.14,15.26 16.1,16.23 18.97,15.95M17.33,17.97C14.5,17.81 11.7,16.64 9.53,14.5C7.36,12.31 6.2,9.5 6.04,6.68C3.23,9.82 3.23,14.71 6.35,17.85C9.48,21 14.37,21 17.33,17.97Z">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="{DynamicResource HeaderTextBrush}"/>
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ThemeIcon}" Value="☀">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsHeroMode}" Value="True">
                                            <Setter Property="Fill" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                        <!-- Солнце — показывается в тёмной теме (переключить в светлую) -->
                        <Path Width="18" Height="18" Stretch="Uniform"
                              Data="M12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,2L14.39,5.42C13.65,5.15 12.84,5 12,5C11.16,5 10.35,5.15 9.61,5.42L12,2M3.34,7L7.5,6.65C6.9,7.16 6.36,7.78 5.94,8.5C5.5,9.24 5.25,10 5.11,10.79L3.34,7M3.36,17L5.12,13.23C5.26,14 5.53,14.78 5.95,15.5C6.37,16.24 6.91,16.86 7.5,17.37L3.36,17M20.65,7L18.88,10.79C18.74,10 18.47,9.23 18.05,8.5C17.63,7.78 17.1,7.15 16.5,6.64L20.65,7M20.64,17L16.5,17.36C17.09,16.85 17.62,16.22 18.04,15.5C18.46,14.77 18.73,14 18.87,13.2L20.64,17M12,22L9.59,18.56C10.33,18.83 11.14,19 12,19C12.86,19 13.67,18.83 14.41,18.56L12,22Z">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="{DynamicResource HeaderTextBrush}"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ThemeIcon}" Value="☀">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsHeroMode}" Value="True">
                                            <Setter Property="Fill" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Grid>
                </Button>

                <!-- Разделитель: серый на светлом, полупрозрачный в hero -->
                <Rectangle Width="1" Height="22" Margin="0,0,10,0">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Fill" Value="{DynamicResource BorderBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHeroMode}" Value="True">
                                    <Setter Property="Fill" Value="#40FFFFFF"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <!-- Избранное (только клиенты): красное сердце + счётчик -->
                <Button Style="{StaticResource IconBtn}"
                        Command="{Binding GoToFavoritesCommand}"
                        ToolTip="Избранное" Margin="0,0,8,0"
                        Visibility="{Binding IsClientUser, Converter={StaticResource BoolToVisibility}}">
                    <Grid Width="24" Height="24">
                        <Path Data="M12 21.593C6.37 16.054 0 12.436 0 7.641 0 4.573 2.38 2 5.127 2c1.799 0 3.394 1.105 4.873 3.304C11.48 3.105 13.074 2 14.873 2 17.62 2 20 4.573 20 7.641c0 4.795-6.37 8.413-12 13.952z"
                              Width="16" Height="16" Stretch="Uniform" Fill="#EF5350"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border Background="#EF5350" CornerRadius="7" MinWidth="14" Height="14"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Padding="3,0"
                                Visibility="{Binding FavoritesCount, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding FavoritesCount}" FontSize="9" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Не авторизован: Войти -->
                <Button Command="{Binding GoToLoginCommand}" Cursor="Hand"
                        Visibility="{Binding IsNotLoggedIn, Converter={StaticResource BoolToVisibility}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{DynamicResource PrimaryBrush}"
                                                CornerRadius="6" Padding="28,0" Height="42">
                                            <TextBlock Text="{DynamicResource Login.SignIn}"
                                                       Foreground="White" FontSize="15" FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource PrimaryHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Авторизован: Мой профиль + Выйти -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">

                    <Button Command="{Binding GoToProfileCommand}" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    CornerRadius="6" Padding="16,0" Height="38">
                                                <TextBlock Text="{DynamicResource Nav.MyProfile}"
                                                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource PrimaryHoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding LogoutCommand}" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground"  Value="{DynamicResource HeaderTextBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="Background"  Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="12,0" Height="38">
                                                <TextBlock Text="{DynamicResource Common.Logout}"
                                                           FontSize="13" FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsHeroMode}" Value="True">
                                        <Setter Property="Foreground"  Value="White"/>
                                        <Setter Property="BorderBrush" Value="#60FFFFFF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
