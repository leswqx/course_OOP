<UserControl x:Class="MSM.Controls.ImageCarouselControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="350" d:DesignWidth="500">

    <Border Background="{DynamicResource PlaceholderBrush}" CornerRadius="8" ClipToBounds="True">
        <Grid>
            <!-- Заглушка когда нет фото -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasImages, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                <TextBlock Text="🏠" FontSize="72" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Common.NoPhotos}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Изображение -->
            <Image Source="{Binding CurrentImage}"
                   Stretch="UniformToFill"
                   Visibility="{Binding HasImages, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Кнопка «Назад» (❮) -->
            <Button Command="{Binding PreviousImageCommand}"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    Width="40" Height="60" Margin="8,0"
                    Background="#88000000" Foreground="White"
                    BorderThickness="0" FontSize="20" Content="❮"
                    Visibility="{Binding HasMultipleImages, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Кнопка «Вперёд» (❯) -->
            <Button Command="{Binding NextImageCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="40" Height="60" Margin="8,0"
                    Background="#88000000" Foreground="White"
                    BorderThickness="0" FontSize="20" Content="❯"
                    Visibility="{Binding HasMultipleImages, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Счётчик фото -->
            <Border Background="#88000000" CornerRadius="10"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,10,10" Padding="10,4"
                    Visibility="{Binding HasImages, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding ImageCounter}"
                           Foreground="White" FontSize="12"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
