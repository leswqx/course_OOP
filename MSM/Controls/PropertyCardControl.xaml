<UserControl x:Class="MSM.Controls.PropertyCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="280">

    <Border Width="280"
            Background="{DynamicResource CardBrush}"
            CornerRadius="12"
            ClipToBounds="True"
            Margin="8"
            Cursor="Hand">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="130"/>
            </Grid.RowDefinitions>

<Grid Grid.Row="0" ClipToBounds="True">

<Border Background="{DynamicResource PlaceholderBrush}" CornerRadius="12 12 0 0"
                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Width="52" Height="52" Stretch="Uniform" HorizontalAlignment="Center"
                              Fill="{DynamicResource TextSecondaryBrush}"
                              Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/>
                        <TextBlock Text="{DynamicResource Common.NoPhoto}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

<Image Source="{Binding MainImage}" 
                       Stretch="UniformToFill"
                       Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"
                        />

<Border HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,10,10,0" Background="#CC000000" CornerRadius="12"
                        Width="26" Height="26"
                        Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibility}}">
                    <Path Data="M12 21.593C6.37 16.054 0 12.436 0 7.641 0 4.573 2.38 2 5.127 2c1.799 0 3.394 1.105 4.873 3.304C11.48 3.105 13.074 2 14.873 2 17.62 2 20 4.573 20 7.641c0 4.795-6.37 8.413-12 13.952z"
                          Width="13" Height="13" Stretch="Uniform" Fill="#EF5350"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="10,10,0,0">
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="4"
                            Padding="8,3" Margin="0,0,5,0">
                        <TextBlock Text="{Binding PropertyTypeDisplay}"
                                   Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#EF5350" CornerRadius="4" Padding="8,3"
                            Visibility="{Binding IsSold, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{DynamicResource Status.Sold}"
                                   Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>

<StackPanel Grid.Row="1" Margin="14,12,14,12">

<TextBlock Text="{Binding Price, Converter={StaticResource PriceToString}}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           Margin="0,0,0,6"/>

<TextBlock Text="{Binding Title}"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,10"/>

<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Path Width="11" Height="11" Stretch="Uniform" Margin="0,0,5,0"
                          VerticalAlignment="Center"
                          Fill="{DynamicResource PrimaryBrush}"
                          Data="M12,2C8.13,2 5,5.13 5,9c0,5.25 7,13 7,13s7-7.75 7-13C19,5.13 15.87,2 12,2z M12,11.5c-1.38,0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5,1.12 2.5,2.5S13.38,11.5 12,11.5z"/>
                    <TextBlock Text="{Binding City}"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

<WrapPanel Margin="0,2,0,0">
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                            Padding="8,4" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource TextSecondaryBrush}"
                                  Data="M7,13C8.66,13 10,11.66 10,10C10,8.34 8.66,7 7,7C5.34,7 4,8.34 4,10C4,11.66 5.34,13 7,13ZM19,7H11V14H3V7H1V20H3V17H21V20H23V11C23,8.79 21.21,7 19,7Z"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Text="{Binding Rooms, StringFormat='{}{0} комн.'}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                            Padding="8,4" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="11" Height="11" Stretch="Uniform" Margin="0,0,4,0"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource TextSecondaryBrush}"
                                  Data="M21,3H3C1.9,3 1,3.9 1,5V19C1,20.1 1.9,21 3,21H21C22.1,21 23,20.1 23,19V5C23,3.9 22.1,3 21,3ZM21,19H3V5H21V19Z"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Text="{Binding Area, StringFormat='{}{0:F0} м²'}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                            Padding="8,4"
                            Visibility="{Binding Bathrooms, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="11" Height="11" Stretch="Uniform" Margin="0,0,4,0"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource TextSecondaryBrush}"
                                  Data="M9,2A1,1 0 0,0 8,3V5H5C3.9,5 3,5.9 3,7V20A1,1 0 0,0 4,21H20A1,1 0 0,0 21,20V7C21,5.9 20.1,5 19,5H16V3A1,1 0 0,0 15,2H9M9,4H15V5H9V4M5,7H19V19H5V7M9,9V11H7V13H9V15H11V13H13V11H11V9H9M13,9V11H15V13H13V15H15V17H17V15H15V13H17V11H15V9H13Z"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Text="{Binding Bathrooms}"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
