<UserControl x:Class="MSM.Controls.PropertyCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="320" d:DesignWidth="280">

    <Border Width="280" MinHeight="320"
            Background="{DynamicResource CardBrush}"
            CornerRadius="8"
            Margin="8"
            Cursor="Hand">
        <Border.Effect>
            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="10" ShadowDepth="2" Opacity="0.25"/>
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Фото объекта -->
            <Grid Grid.Row="0" ClipToBounds="True">

                <!-- Заглушка когда нет фото -->
                <Border Background="{DynamicResource PlaceholderBrush}"
                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🏠" FontSize="52" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Common.NoPhoto}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Фото из БД -->
                <Image Source="{Binding MainImage}"
                       Stretch="UniformToFill"
                       Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Бейдж типа объекта -->
                <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="4"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="10,10,0,0" Padding="8,3">
                    <TextBlock Text="{Binding PropertyTypeDisplay}"
                               Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- Информация -->
            <StackPanel Grid.Row="1" Margin="14,10,14,14">

                <!-- Цена -->
                <TextBlock Text="{Binding Price, Converter={StaticResource PriceToString}}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"/>

                <!-- Название -->
                <TextBlock Text="{Binding Title}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           MaxHeight="38"
                           Margin="0,5,0,0"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Площадь / комнаты -->
                <TextBlock Text="{Binding AreaRoomsInfo}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                           Margin="0,6,0,0"/>

                <!-- Город -->
                <TextBlock Text="{Binding City}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
