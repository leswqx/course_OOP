<Window x:Class="MSM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Агентство недвижимости - MSM"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        xmlns:converters="clr-namespace:MSM.Converters">
    <Grid>
        <ContentControl Content="{Binding CurrentViewModel}"/>

        <!-- Глобальная навигация: Назад + Главная (скрыта на лендинге) -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                Margin="12,10" Panel.ZIndex="100"
                Visibility="{Binding ShowGlobalNav, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <!-- Назад -->
                <Button Command="{Binding GoBackCommand}"
                        Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,0,6,0" Cursor="Hand" ToolTip="Назад">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#CC000000" CornerRadius="8" Padding="12,7">
                                            <TextBlock Text="← Назад" Foreground="White" FontSize="13"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#EE000000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Главная -->
                <Button Command="{Binding GoHomeCommand}" Cursor="Hand" ToolTip="На главную">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#CC000000" CornerRadius="8" Padding="10,7">
                                            <TextBlock Text="🏠" FontSize="14"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#EE000000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
