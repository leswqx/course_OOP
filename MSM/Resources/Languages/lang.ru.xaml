    <s:String x:Key="Nav.Favorites">⭐ Избранное</s:String>
    <s:String x:Key="Nav.MyAppt">📅 Мои записи</s:String>
    <s:String x:Key="Nav.Realtor">📋 Кабинет</s:String>
    <s:String x:Key="Nav.Admin">⚙ Админ</s:String>

    <!-- HomeView -->
    <s:String x:Key="Home.LogoutButton">Выйти из системы</s:String>
    <s:String x:Key="Home.Placeholder">Функциональность будет добавлена на следующих этапах разработки.</s:String>

</ResourceDictionary>
