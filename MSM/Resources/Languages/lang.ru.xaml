<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">

    <!-- Общие -->
    <s:String x:Key="App.Title">Агентство недвижимости</s:String>
    <s:String x:Key="Common.Loading">Загрузка...</s:String>
    <s:String x:Key="Common.NoPhoto">Нет фото</s:String>
    <s:String x:Key="Common.NoPhotos">Фотографии отсутствуют</s:String>
    <s:String x:Key="Common.Logout">Выйти</s:String>
    <s:String x:Key="Common.Search">Найти</s:String>
    <s:String x:Key="Common.Back">← Назад</s:String>
    <s:String x:Key="Common.Yes">✓ Есть</s:String>
    <s:String x:Key="Common.No">✗ Нет</s:String>
    <s:String x:Key="Common.Available">✓ Доступна</s:String>

    <!-- Типы объектов -->
    <s:String x:Key="Type.Apartment">Квартира</s:String>
    <s:String x:Key="Type.House">Дом</s:String>
    <s:String x:Key="Type.Complex">Комплекс</s:String>

    <!-- Статусы -->
    <s:String x:Key="Status.Active">Активен</s:String>
    <s:String x:Key="Status.Sold">Продан</s:String>
    <s:String x:Key="Status.Hidden">Скрыт</s:String>

    <!-- Вход -->
    <s:String x:Key="Login.Subtitle">Вход в систему</s:String>
    <s:String x:Key="Login.LoginLabel">Логин</s:String>
    <s:String x:Key="Login.PasswordLabel">Пароль</s:String>
    <s:String x:Key="Login.SignIn">Войти</s:String>
    <s:String x:Key="Login.Register">Зарегистрироваться</s:String>

    <!-- Каталог -->
    <s:String x:Key="Catalog.BackToList">← Назад к каталогу</s:String>
    <s:String x:Key="Catalog.NoResults">Объекты не найдены</s:String>
    <s:String x:Key="Catalog.NoResultsHint">Попробуйте изменить строку поиска</s:String>

    <!-- Детальная страница -->
    <s:String x:Key="Detail.Area">Площадь</s:String>
    <s:String x:Key="Detail.Rooms">Комнат</s:String>
    <s:String x:Key="Detail.Floor">Этаж</s:String>
    <s:String x:Key="Detail.YearBuilt">Год постройки</s:String>
    <s:String x:Key="Detail.Renovation">Ремонт</s:String>
    <s:String x:Key="Detail.Mortgage">Ипотека</s:String>
    <s:String x:Key="Detail.Address">📍  Адрес</s:String>
    <s:String x:Key="Detail.Realtor">👤  Риелтор</s:String>
    <s:String x:Key="Detail.Description">Описание</s:String>
    <s:String x:Key="Detail.AddFavorite">☆  В избранное</s:String>
    <s:String x:Key="Detail.InFavorite">★  В избранном</s:String>
    <s:String x:Key="Detail.Schedule">📅  Записаться на просмотр</s:String>
    <s:String x:Key="Detail.ComingSoon">Будет доступно в следующей версии</s:String>

    <!-- Фильтры (Phase 9) -->
    <s:String x:Key="Filter.Title">Фильтры</s:String>
    <s:String x:Key="Filter.Price">Цена, ₽</s:String>
    <s:String x:Key="Filter.Area">Площадь, м²</s:String>
    <s:String x:Key="Filter.Rooms">Комнат</s:String>
    <s:String x:Key="Filter.City">Город</s:String>
    <s:String x:Key="Filter.Type">Тип объекта</s:String>
    <s:String x:Key="Filter.From">от</s:String>
    <s:String x:Key="Filter.To">до</s:String>
    <s:String x:Key="Filter.Apply">Применить</s:String>
    <s:String x:Key="Filter.Reset">Сбросить</s:String>
    <s:String x:Key="Filter.AllCities">Все города</s:String>
    <s:String x:Key="Filter.AllTypes">Все типы</s:String>
    <s:String x:Key="Filter.Mortgage">Ипотека</s:String>
    <s:String x:Key="Filter.Renovation">С ремонтом</s:String>

    <!-- Регистрация -->
    <s:String x:Key="Register.Subtitle">Создание аккаунта</s:String>
    <s:String x:Key="Register.FullName">Полное имя *</s:String>
    <s:String x:Key="Register.Email">E-mail *</s:String>
    <s:String x:Key="Register.Phone">Телефон</s:String>
    <s:String x:Key="Register.ConfirmPassword">Подтвердите пароль *</s:String>
    <s:String x:Key="Register.Submit">Зарегистрироваться</s:String>

    <!-- Запись на просмотр (Phase 10) -->
    <s:String x:Key="Schedule.FormTitle">Записаться на просмотр</s:String>
    <s:String x:Key="Schedule.Date">Дата</s:String>
    <s:String x:Key="Schedule.Time">Время</s:String>
    <s:String x:Key="Schedule.Comment">Комментарий (необязательно)</s:String>
    <s:String x:Key="Schedule.Submit">Подтвердить запись</s:String>
    <s:String x:Key="Schedule.Cancel">Отмена</s:String>
    <s:String x:Key="Schedule.Success">✓ Запись оформлена! Риелтор свяжется с вами.</s:String>
    <s:String x:Key="Schedule.SlotTaken">Это время уже занято. Выберите другой слот.</s:String>

    <!-- Избранное -->
    <s:String x:Key="Favorites.Title">Избранное</s:String>
    <s:String x:Key="Favorites.Empty">Вы ещё не добавили объекты в избранное</s:String>

    <!-- Мои записи (клиент) -->
    <s:String x:Key="MyAppt.Title">Мои записи на просмотр</s:String>
    <s:String x:Key="MyAppt.Empty">У вас пока нет записей на просмотр</s:String>
    <s:String x:Key="MyAppt.Property">Объект</s:String>
    <s:String x:Key="MyAppt.DateTime">Дата и время</s:String>
    <s:String x:Key="MyAppt.Status">Статус</s:String>
    <s:String x:Key="MyAppt.Comment">Комментарий</s:String>
    <s:String x:Key="Appt.New">Новая</s:String>
    <s:String x:Key="Appt.Confirmed">Подтверждена</s:String>
    <s:String x:Key="Appt.Cancelled">Отменена</s:String>
    <s:String x:Key="Appt.Completed">Завершена</s:String>

    <!-- Панель риелтора -->
    <s:String x:Key="Realtor.Title">Панель риелтора</s:String>
    <s:String x:Key="Realtor.MyProperties">Мои объекты</s:String>
    <s:String x:Key="Realtor.Appointments">Записи клиентов</s:String>
    <s:String x:Key="Realtor.AddProperty">+ Добавить объект</s:String>
    <s:String x:Key="Realtor.Confirm">Подтвердить</s:String>
    <s:String x:Key="Realtor.Cancel">Отменить</s:String>
    <s:String x:Key="Realtor.NoAppt">Нет записей</s:String>

    <!-- Форма объекта -->
    <s:String x:Key="PropForm.Title">Название *</s:String>
    <s:String x:Key="PropForm.Description">Описание *</s:String>
    <s:String x:Key="PropForm.Price">Цена, ₽ *</s:String>
    <s:String x:Key="PropForm.Area">Площадь, м² *</s:String>
    <s:String x:Key="PropForm.Rooms">Комнат *</s:String>
    <s:String x:Key="PropForm.Floor">Этаж</s:String>
    <s:String x:Key="PropForm.TotalFloors">Всего этажей</s:String>
    <s:String x:Key="PropForm.YearBuilt">Год постройки</s:String>
    <s:String x:Key="PropForm.City">Город *</s:String>
    <s:String x:Key="PropForm.Address">Адрес *</s:String>
    <s:String x:Key="PropForm.Type">Тип объекта *</s:String>
    <s:String x:Key="PropForm.HasRepair">Есть ремонт</s:String>
    <s:String x:Key="PropForm.Mortgage">Доступна ипотека</s:String>
    <s:String x:Key="PropForm.Save">Сохранить</s:String>
    <s:String x:Key="PropForm.Cancel">Отмена</s:String>

    <!-- Панель администратора -->
    <s:String x:Key="Admin.Title">Панель администратора</s:String>
    <s:String x:Key="Admin.Users">Пользователи</s:String>
    <s:String x:Key="Admin.Reviews">Модерация отзывов</s:String>
    <s:String x:Key="Admin.Stats">Статистика</s:String>
    <s:String x:Key="Admin.Approve">Одобрить</s:String>
    <s:String x:Key="Admin.Reject">Отклонить</s:String>
    <s:String x:Key="Admin.NoReviews">Нет отзывов на модерации</s:String>
    <s:String x:Key="Admin.TotalProps">Всего объектов</s:String>
    <s:String x:Key="Admin.ActiveProps">Активных</s:String>
    <s:String x:Key="Admin.SoldProps">Продано</s:String>
    <s:String x:Key="Admin.TotalUsers">Пользователей</s:String>

