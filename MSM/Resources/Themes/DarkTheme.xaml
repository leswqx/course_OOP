<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Основные цвета -->
    <Color x:Key="PrimaryColor">#D4A5A5</Color>
    <Color x:Key="BackgroundColor">#1E1E1E</Color>
    <Color x:Key="ShadowColor">#000000</Color>

    <!-- Кисти -->
    <SolidColorBrush x:Key="BackgroundBrush"      Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="#2D2D2D"/>
    <SolidColorBrush x:Key="HeaderBrush"          Color="#252525"/>
    <SolidColorBrush x:Key="CardBrush"            Color="#2D2D2D"/>
    <SolidColorBrush x:Key="InputBrush"           Color="#333333"/>
    <SolidColorBrush x:Key="PrimaryBrush"         Color="#D4A5A5"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"    Color="#C49595"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="#C49595"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#A0A0A0"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="#444444"/>
    <SolidColorBrush x:Key="PlaceholderBrush"     Color="#3A3A3A"/>
    <SolidColorBrush x:Key="ButtonSecondaryBg"    Color="#3A2A2A"/>
    <SolidColorBrush x:Key="BadgePlaceholderBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="SuccessBrush"         Color="#8BC34A"/>
    <SolidColorBrush x:Key="ErrorBrush"           Color="#EF5350"/>
    <SolidColorBrush x:Key="SeparatorBrush"       Color="#3A3A3A"/>

</ResourceDictionary>
