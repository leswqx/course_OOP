<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Основные цвета -->
    <Color x:Key="PrimaryColor">#3A7D4F</Color>
    <Color x:Key="BackgroundColor">#141F17</Color>
    <Color x:Key="ShadowColor">#000000</Color>

    <!-- Кисти -->
    <SolidColorBrush x:Key="BackgroundBrush"       Color="#141F17"/>
    <SolidColorBrush x:Key="SurfaceBrush"          Color="#1C2B20"/>
    <SolidColorBrush x:Key="HeaderBrush"           Color="#141F17"/>
    <SolidColorBrush x:Key="HeaderTextBrush"       Color="#52A86A"/>
    <SolidColorBrush x:Key="CardBrush"             Color="#1E2D22"/>
    <SolidColorBrush x:Key="InputBrush"            Color="#243428"/>
    <SolidColorBrush x:Key="PrimaryBrush"          Color="#3A7D4F"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"     Color="#4A9061"/>
    <SolidColorBrush x:Key="AccentBrush"           Color="#52A86A"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"      Color="#D4E8D8"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"    Color="#6E9E7A"/>
    <SolidColorBrush x:Key="BorderBrush"           Color="#2E4A36"/>
    <SolidColorBrush x:Key="PlaceholderBrush"      Color="#283E2C"/>
    <SolidColorBrush x:Key="ButtonSecondaryBg"     Color="#1C3224"/>
    <SolidColorBrush x:Key="BadgePlaceholderBrush" Color="#243428"/>
    <SolidColorBrush x:Key="SuccessBrush"          Color="#4CAF6A"/>
    <SolidColorBrush x:Key="ErrorBrush"            Color="#EF5350"/>
    <SolidColorBrush x:Key="SeparatorBrush"        Color="#2A3E2E"/>
    <SolidColorBrush x:Key="RatingBrush"           Color="#F4B942"/>

</ResourceDictionary>
