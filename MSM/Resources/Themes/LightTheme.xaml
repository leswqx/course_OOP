<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Основные цвета -->
    <Color x:Key="PrimaryColor">#D4A5A5</Color>
    <Color x:Key="BackgroundColor">#F5E6E6</Color>
    <Color x:Key="ShadowColor">#AAAAAA</Color>

    <!-- Кисти -->
    <SolidColorBrush x:Key="BackgroundBrush"      Color="#F5E6E6"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderBrush"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBrush"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBrush"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBrush"         Color="#D4A5A5"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"    Color="#C49595"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="#8B6F6F"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#4A4A4A"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#7A7A7A"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="#CCCCCC"/>
    <SolidColorBrush x:Key="PlaceholderBrush"     Color="#F0E0E0"/>
    <SolidColorBrush x:Key="ButtonSecondaryBg"    Color="#F5E6E6"/>
    <SolidColorBrush x:Key="BadgePlaceholderBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="SuccessBrush"         Color="#7CB342"/>
    <SolidColorBrush x:Key="ErrorBrush"           Color="#EF5350"/>
    <SolidColorBrush x:Key="SeparatorBrush"       Color="#EEEEEE"/>

</ResourceDictionary>
