<UserControl x:Class="MSM.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="800" d:DesignWidth="900">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,70,0,0">
        <StackPanel>

            <!-- ══ HERO ══ -->
            <Border Background="{DynamicResource PrimaryBrush}" Padding="40,56,40,56">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource About.Hero}"
                               FontSize="24" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock Text="{DynamicResource About.HeroSub}"
                               FontSize="13" Foreground="#CCFFFFFF"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               MaxWidth="520" TextWrapping="Wrap" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- ══ STATS ══ -->
            <Border Background="{DynamicResource CardBrush}" Padding="0,32">
                <UniformGrid Rows="1" Columns="3" MaxWidth="680" HorizontalAlignment="Center">

                    <StackPanel HorizontalAlignment="Center" Margin="16,0">
                        <TextBlock Text="{DynamicResource About.StatProps}"
                                   FontSize="40" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource About.StatPropsLabel}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center" Margin="16,0">
                        <TextBlock Text="{DynamicResource About.StatClients}"
                                   FontSize="40" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource About.StatClientsLabel}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center" Margin="16,0">
                        <TextBlock Text="{DynamicResource About.StatRealtors}"
                                   FontSize="40" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource About.StatRealtorsLabel}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                </UniformGrid>
            </Border>

            <!-- ══ SERVICES ══ -->
            <StackPanel Margin="36,36,36,0">
                <TextBlock Text="{DynamicResource About.ServicesTitle}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,18"/>

                <UniformGrid Rows="1" Columns="3">

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Margin="0,0,10,0" Padding="20,24">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>
                        <StackPanel>
                            <Path Width="34" Height="34" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,12"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/>
                            <TextBlock Text="{DynamicResource About.S1Title}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource About.S1Body}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Margin="5,0,5,0" Padding="20,24">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>
                        <StackPanel>
                            <Path Width="34" Height="34" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,12"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Data="M20,8H4V6H20M20,18H4V12H20M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"/>
                            <TextBlock Text="{DynamicResource About.S2Title}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource About.S2Body}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Margin="10,0,0,0" Padding="20,24">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>
                        <StackPanel>
                            <Path Width="34" Height="34" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,12"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Data="M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V6A2,2 0 0,0 19,4M19,20H5V10H19V20M19,8H5V6H19V8Z"/>
                            <TextBlock Text="{DynamicResource About.S3Title}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource About.S3Body}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </StackPanel>

            <!-- ══ CONTACTS ══ -->
            <Border Background="{DynamicResource CardBrush}" Margin="36,28,36,40"
                    CornerRadius="8" Padding="30,28">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource About.ContactsTitle}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,18"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Data="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z"/>
                            <TextBlock Text="{DynamicResource About.Phone}"
                                       FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"/>
                            <TextBlock Text="{DynamicResource About.Email}"
                                       FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Data="M12,2C8.13,2 5,5.13 5,9C5,14.25 12,22 12,22C12,22 19,14.25 19,9C19,5.13 15.87,2 12,2M12,11.5C10.62,11.5 9.5,10.38 9.5,9C9.5,7.62 10.62,6.5 12,6.5C13.38,6.5 14.5,7.62 14.5,9C14.5,10.38 13.38,11.5 12,11.5Z"/>
                            <TextBlock Text="{DynamicResource About.Address}"
                                       FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M16.2,16.2L11,13V7H12.5V12.2L17,14.9L16.2,16.2Z"/>
                            <TextBlock Text="{DynamicResource About.Hours}"
                                       FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- MAP CARD -->
                    <Border Grid.Column="1" CornerRadius="8" ClipToBounds="True"
                            Margin="24,0,0,0" Height="160"
                            VerticalAlignment="Center">

                        <Grid>
                            <Image Source="/Resources/Images/map.png" Stretch="UniformToFill"/>

                            <!-- Радиальное затемнение по краям -->
                            

                            <!-- Белая кнопка по центру -->
                            <Button HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Cursor="Hand" Command="{Binding OpenMapCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="White"
                                                CornerRadius="12" Padding="18,11">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" BlurRadius="14"
                                                                  ShadowDepth="2" Opacity="0.18"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- SVG-пин локации -->
                                    <Path Width="16" Height="16" Stretch="Uniform"
                                          Fill="#EF5350" Margin="0,0,8,0" VerticalAlignment="Center"
                                          Data="M12,2C8.13,2 5,5.13 5,9c0,5.25 7,13 7,13s7-7.75 7-13C19,5.13 15.87,2 12,2z M12,11.5c-1.38,0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5,1.12 2.5,2.5-1.12,2.5-2.5,2.5z"/>
                                    <TextBlock Text="{DynamicResource About.ViewOnMap}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#1A1A1A" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- Кнопка профиля администратора — только для admin -->
            <Border Margin="36,0,36,40" HorizontalAlignment="Left"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                <Button Command="{Binding GoToAdminProfileCommand}" Cursor="Hand"
                        Height="36" Padding="20,0" FontSize="13"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"
                              VerticalAlignment="Center" Fill="White"
                              Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                        <TextBlock Text="{DynamicResource About.AdminProfile}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
