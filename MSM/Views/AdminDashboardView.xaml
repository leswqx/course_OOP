                                     Height="36" Padding="10,0" FontSize="13"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                            <Button Grid.Column="2" Content="{DynamicResource Common.Search}" Command="{Binding SearchAdminPropsCommand}"
                                    Height="36" Padding="16,0" FontSize="13"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Foreground="White" BorderThickness="0"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource Admin.FilterAll}" Command="{Binding FilterAdminAllCommand}"
                                    Height="30" Padding="12,0" FontSize="12" Margin="0,0,6,0" BorderThickness="1">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAdminPropFilterAll}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{DynamicResource Admin.PropFilterActive}" Command="{Binding FilterAdminActiveCommand}"
                                    Height="30" Padding="12,0" FontSize="12" Margin="0,0,6,0" BorderThickness="1">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAdminPropFilterActive}" Value="True">
                                                <Setter Property="Background" Value="#7CB342"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#7CB342"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{DynamicResource Admin.PropFilterHidden}" Command="{Binding FilterAdminHiddenCommand}"
                                    Height="30" Padding="12,0" FontSize="12" Margin="0,0,6,0" BorderThickness="1">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAdminPropFilterHidden}" Value="True">
                                                <Setter Property="Background" Value="#9E9E9E"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#9E9E9E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{DynamicResource Admin.PropFilterSold}" Command="{Binding FilterAdminSoldCommand}"
                                    Height="30" Padding="12,0" FontSize="12" Margin="0,0,16,0" BorderThickness="1">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAdminPropFilterSold}" Value="True">
                                                <Setter Property="Background" Value="#F4B942"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#F4B942"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{DynamicResource Admin.ReviewRealtorLabel}" VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ComboBox ItemsSource="{Binding AdminRealtorNames}"
                                      SelectedItem="{Binding AdminPropRealtorFilter}"
                                      Height="30" Width="180" FontSize="12">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="">
                                                            <Setter Property="Text" Value="{DynamicResource Admin.AllRealtors}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

<TextBlock Grid.Row="2" Margin="0,0,0,8" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="{DynamicResource Admin.PropFound}"/>
                    <Run Text="{Binding AdminPropsCount}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Run Text="{DynamicResource Admin.PropObjects}"/>
                </TextBlock>

<ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AdminProperties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                                        Padding="14,10" Margin="0,0,0,6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.07"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

<StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding City}" FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text=" · " FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding PropertyType}" FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text=" · " FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding Price}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{DynamicResource Admin.RealtorPrefix}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding RealtorName}" FontSize="11"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                                <TextBlock Text="{DynamicResource Admin.AddedPrefix}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding CreatedAt}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>

<Border Grid.Column="1" CornerRadius="4" Padding="10,3"
                                                VerticalAlignment="Center" Margin="12,0"
                                                Background="{Binding StatusColor, Converter={StaticResource StringToBrush}}">
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="12"
                                                       FontWeight="SemiBold" Foreground="White"/>
                                        </Border>

<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="{DynamicResource Admin.OpenBtn}"
                                                    Command="{Binding DataContext.OpenAdminPropertyDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Height="30" Padding="12,0" FontSize="12" Margin="0,0,6,0"
                                                    Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                            <Button Content="{Binding ToggleHideLabel}"
                                                    Command="{Binding DataContext.ToggleAdminPropertyStatusCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanToggleHide, Converter={StaticResource BoolToVisibility}}"
                                                    Height="30" Padding="12,0" FontSize="12" Margin="0,0,6,0"
                                                    Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                            <Button Content="{DynamicResource Admin.DeleteBtn}"
                                                    Command="{Binding DataContext.DeleteAdminPropertyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Height="30" Padding="12,0" FontSize="12"
                                                    Background="Transparent" Foreground="#EF5350"
                                                    BorderBrush="#EF5350" BorderThickness="1"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

<ScrollViewer Visibility="{Binding ShowTab3, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto">
                <Grid Margin="24,24,24,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

<Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="28,20">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="90" Height="90" CornerRadius="45" ClipToBounds="True"
                                    Background="{DynamicResource PlaceholderBrush}" Margin="0,0,0,10">
                                <Grid>
                                    <Path Width="40" Height="40" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Visibility="{Binding ProfileAvatar, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}"
                                          Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                    <Image Source="{Binding ProfileAvatar, Converter={StaticResource ByteArrayToImage}}" Stretch="UniformToFill"
                                           Visibility="{Binding ProfileAvatar, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding ProfileLogin}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Admin.RoleLabel}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="{DynamicResource Profile.UploadPhoto}" Command="{Binding UploadProfileAvatarCommand}"
                                        Height="30" Padding="14,0" FontSize="12" Margin="0,0,8,0"
                                        Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                                <Button Content="{DynamicResource Profile.RemovePhoto}" Command="{Binding RemoveProfileAvatarCommand}"
                                        Height="30" Padding="14,0" FontSize="12"
                                        Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Visibility="{Binding ProfileAvatar, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

<Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

<Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="28,24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="14" ShadowDepth="2" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Profile.PersonalData}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,22"/>
                                <TextBlock Text="{DynamicResource Profile.FullName}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfileFullName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="{DynamicResource Profile.Email}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfileEmail, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="{DynamicResource Profile.Phone}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfilePhone, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,22"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <Button Content="{DynamicResource Profile.Save}" Command="{Binding SaveProfileCommand}"
                                        Height="44" FontSize="14" FontWeight="SemiBold"
                                        Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                                <TextBlock Margin="0,12,0,0" FontSize="13" TextWrapping="Wrap"
                                           Text="{Binding ProfileResult}"
                                           Visibility="{Binding ProfileResult, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProfileSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ProfileSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

<Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="28,24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="14" ShadowDepth="2" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Profile.ChangePassword}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,22"/>
                                <TextBlock Text="{DynamicResource Profile.OldPassword}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding ProfileOldPassword, Mode=TwoWay}"
                                             Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="{DynamicResource Profile.NewPassword}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding ProfileNewPassword, Mode=TwoWay}"
                                             Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="{DynamicResource Profile.ConfirmPassword}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding ProfileConfirmPassword, Mode=TwoWay}"
                                             Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,22"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <Button Content="{DynamicResource Profile.ChangePasswordBtn}" Command="{Binding ChangeProfilePasswordCommand}"
                                        Height="44" FontSize="14" FontWeight="SemiBold"
                                        Background="Transparent"
                                        Foreground="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"/>
                                <TextBlock Margin="0,12,0,0" FontSize="13" TextWrapping="Wrap"
                                           Text="{Binding PasswordResult}"
                                           Visibility="{Binding PasswordResult, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PasswordSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PasswordSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>

