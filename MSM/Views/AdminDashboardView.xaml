<UserControl x:Class="MSM.Views.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:MSM.Helpers"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Margin="0,70,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Вкладки -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="16,0">
                <!-- Профиль — первый -->
                <Button Content="{DynamicResource Nav.MyProfile}"
                        Command="{Binding SetTab3Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab3}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Admin.Users}"
                        Command="{Binding SetTab0Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab0}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding SetTab1Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Admin.Reviews}" VerticalAlignment="Center"/>
                            <Border Background="#EF5350" CornerRadius="10" Padding="5,1" Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding PendingReviewsCount, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding PendingReviewsCount}" FontSize="10"
                                           Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button.Content>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab1}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Admin.Stats}"
                        Command="{Binding SetTab2Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab2}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Рассылка"
                        Command="{Binding SetTab4Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab4}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <Grid Grid.Row="1">

            <!-- ===== ВКЛАДКА 0: ПОЛЬЗОВАТЕЛИ ===== -->
            <Grid Visibility="{Binding ShowTab0, Converter={StaticResource BoolToVisibility}}"
                  Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Сообщение об операции -->
                <Border Grid.Row="0" CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                        Visibility="{Binding UserActionMessage, Converter={StaticResource BoolToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding UserActionMessage}" FontSize="13"
                               Foreground="White" FontWeight="SemiBold"/>
                </Border>

                <!-- Поиск -->
                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding UserSearch, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" FontSize="13" Padding="10,0"
                             Background="{DynamicResource InputBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <Button Grid.Column="1" Content="Найти"
                            Command="{Binding SearchUsersCommand}"
                            Height="36" Margin="8,0,0,0" FontSize="12"
                            Background="{DynamicResource PrimaryBrush}"
                            Foreground="White" BorderThickness="0"/>
                </Grid>

                <!-- Фильтры по роли -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Все" Command="{Binding FilterAllCommand}"
                            Height="28" Padding="14,0" FontSize="12" Margin="0,0,6,0"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserRoleFilter}" Value="all">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Риелторы" Command="{Binding FilterRealtorCommand}"
                            Height="28" Padding="14,0" FontSize="12" Margin="0,0,6,0"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserRoleFilter}" Value="realtor">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Клиенты" Command="{Binding FilterClientCommand}"
                            Height="28" Padding="14,0" FontSize="12" Margin="0,0,6,0"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserRoleFilter}" Value="client">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🔒 Заблокированные" Command="{Binding FilterBlockedCommand}"
                            Height="28" Padding="14,0" FontSize="12"
                            BorderThickness="1" BorderBrush="#EF5350">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="#EF5350"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserRoleFilter}" Value="blocked">
                                        <Setter Property="Background" Value="#EF5350"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Таблица пользователей -->
                <DataGrid Grid.Row="3" ItemsSource="{Binding Users}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False"
                          Background="{DynamicResource SurfaceBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          RowBackground="{DynamicResource SurfaceBrush}"
                          AlternatingRowBackground="{DynamicResource BackgroundBrush}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource SeparatorBrush}"
                          HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="8,6"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Имя" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" VerticalAlignment="Center"/>
                                        <Border Background="#EF5350" CornerRadius="3" Padding="4,1"
                                                Margin="6,0,0,0"
                                                Visibility="{Binding ShowBlockedBadge, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="БАН" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Логин"   Binding="{Binding Login}"       Width="110"/>
                        <DataGridTextColumn Header="E-mail"  Binding="{Binding Email}"       Width="160"/>
                        <DataGridTextColumn Header="Роль"    Binding="{Binding RoleDisplay}" Width="100"/>
                        <DataGridTextColumn Header="Создан"  Binding="{Binding CreatedAt}"   Width="90"/>
                        <DataGridTemplateColumn Header="Действия" Width="230">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <Button Content="{DynamicResource Admin.Promote}"
                                                Command="{Binding DataContext.PromoteToRealtorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}"
                                                Visibility="{Binding CanPromote, Converter={StaticResource BoolToVisibility}}"
                                                Height="26" Padding="8,0" FontSize="11"
                                                Background="{DynamicResource PrimaryBrush}"
                                                Foreground="White" BorderThickness="0" Margin="0,0,4,0"/>
                                        <Button Content="{DynamicResource Admin.Demote}"
                                                Command="{Binding DataContext.DemoteToClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}"
                                                Visibility="{Binding CanDemote, Converter={StaticResource BoolToVisibility}}"
                                                Height="26" Padding="8,0" FontSize="11"
                                                Background="#FF8F00"
                                                Foreground="White" BorderThickness="0" Margin="0,0,4,0"/>
                                        <Button Content="{Binding BlockLabel}"
                                                Command="{Binding DataContext.ToggleBlockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}"
                                                Height="26" Padding="8,0" FontSize="11"
                                                BorderThickness="1" BorderBrush="#EF5350"
                                                Background="Transparent" Foreground="#EF5350"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ===== ВКЛАДКА 1: МОДЕРАЦИЯ ОТЗЫВОВ ===== -->
            <Grid Visibility="{Binding ShowTab1, Converter={StaticResource BoolToVisibility}}"
                  Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Фильтр по риелтору -->
                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Риелтор:" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <ComboBox SelectedItem="{Binding ReviewRealtorFilter, Mode=TwoWay}"
                                  ItemsSource="{Binding ReviewRealtorNames}"
                                  Width="240" Height="30"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="">
                                                        <Setter Property="Text" Value="Все риелторы"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding NoReviews, Converter={StaticResource BoolToVisibility}}">
                    <Path Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center"
                          Fill="{DynamicResource TextSecondaryBrush}"
                          Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"/>
                    <TextBlock Text="{DynamicResource Admin.NoReviews}" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PendingReviews}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                        Padding="16,12" Margin="0,0,0,8">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="4" ShadowDepth="1" Opacity="0.08"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Author}" FontWeight="SemiBold"
                                                           FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Rating}" FontSize="13"
                                                           Foreground="{DynamicResource PrimaryBrush}" Margin="12,0,0,0"/>
                                                <TextBlock Text="{Binding Date}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Comment}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="{DynamicResource Admin.Approve}"
                                                    Command="{Binding DataContext.ApproveReviewCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Height="32" Padding="12,0" FontSize="12" Margin="0,0,8,0"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    Foreground="White" BorderThickness="0"/>
                                            <Button Content="{DynamicResource Admin.Reject}"
                                                    Command="{Binding DataContext.RejectReviewCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Height="32" Padding="12,0" FontSize="12"
                                                    Background="{DynamicResource ErrorBrush}"
                                                    Foreground="White" BorderThickness="0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ===== ВКЛАДКА 2: СТАТИСТИКА ===== -->
            <ScrollViewer Visibility="{Binding ShowTab2, Converter={StaticResource BoolToVisibility}}"
                          Margin="16" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Тревожные сигналы -->
                    <Border Visibility="{Binding HasAlerts, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Padding="0" Margin="0,0,0,14">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Заголовок -->
                            <Border Background="#EF5350" CornerRadius="8,8,0,0" Padding="16,10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⚠" FontSize="14" Foreground="White" Margin="0,0,8,0"/>
                                        <TextBlock Text="Тревожные сигналы" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Background="#33FFFFFF" CornerRadius="10" Padding="10,2">
                                        <TextBlock Text="{Binding Alerts.Count, Mode=OneWay}"
                                                   FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- Строки алертов -->
                            <ItemsControl ItemsSource="{Binding Alerts}" Margin="0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0" Margin="0,0,0,1"
                                                Background="{DynamicResource SurfaceBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Цветная полоска слева -->
                                                <Border Grid.Column="0" Background="{Binding AlertColor}"
                                                        CornerRadius="0"/>
                                                <!-- Иконка -->
                                                <TextBlock Grid.Column="1" Text="{Binding Icon}"
                                                           FontSize="16" VerticalAlignment="Center"
                                                           Margin="12,10,8,10"/>
                                                <!-- Текст -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                            Margin="0,10,12,10">
                                                    <TextBlock Text="{Binding RealtorName}" FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding AlertText}" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <!-- Бейдж уровня -->
                                                <Border Grid.Column="3" Background="{Binding AlertColor}"
                                                        CornerRadius="4" Padding="8,3" Margin="0,0,12,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Severity}" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Фильтр периода -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Период:" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button Content="Всё время"     Command="{Binding SetPeriodAllCommand}"       Margin="0,0,6,0" Height="30" Padding="14,0" FontSize="12" Cursor="Hand">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsPeriodAll}" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            <Button Content="Этот месяц"   Command="{Binding SetPeriodMonthCommand}"     Margin="0,0,6,0" Height="30" Padding="14,0" FontSize="12" Cursor="Hand">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsPeriodMonth}" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            <Button Content="Прошлый месяц" Command="{Binding SetPeriodLastMonthCommand}" Margin="0,0,6,0" Height="30" Padding="14,0" FontSize="12" Cursor="Hand">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsPeriodLastMonth}" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            <Button Content="Квартал"       Command="{Binding SetPeriodQuarterCommand}"  Margin="0,0,6,0" Height="30" Padding="14,0" FontSize="12" Cursor="Hand">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsPeriodQuarter}" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            <Button Content="Этот год"      Command="{Binding SetPeriodYearCommand}"     Height="30" Padding="14,0" FontSize="12" Cursor="Hand">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsPeriodYear}" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Глобальные счётчики (всегда за всё время) -->
                    <UniformGrid Columns="5" Margin="0,0,0,8">

                        <!-- Все объекты -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,8,0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#1565C0"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Admin.TotalProps}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding StatTotalProps}" FontSize="30" FontWeight="Bold"
                                               Foreground="#1565C0" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Активных -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,8,0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#2E7D32"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Admin.ActiveProps}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding StatActiveProps}" FontSize="30" FontWeight="Bold"
                                               Foreground="#2E7D32" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Продано -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,8,0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#00897B"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Admin.SoldProps}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding StatSoldProps}" FontSize="30" FontWeight="Bold"
                                               Foreground="#00897B" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Пользователей -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,8,0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#8E24AA"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Admin.TotalUsers}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding StatTotalUsers}" FontSize="30" FontWeight="Bold"
                                               Foreground="#8E24AA" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Риелторов -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F57C00"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Admin.TotalRealtors}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding StatRealtors}" FontSize="30" FontWeight="Bold"
                                               Foreground="#F57C00" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </UniformGrid>

                    <!-- Финансовые KPI за выбранный период -->
                    <UniformGrid Columns="4" Margin="0,0,0,14">
                        <Border CornerRadius="8" Padding="16" Margin="0,0,8,0"
                                BorderBrush="#7CB342" BorderThickness="1" Background="{DynamicResource CardBrush}">
                            <StackPanel>
                                <TextBlock Text="Выручка за период" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding StatRevenueText}" FontSize="20" FontWeight="Bold"
                                           Foreground="#7CB342" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="8" Padding="16" Margin="0,0,8,0"
                                BorderBrush="#42A5F5" BorderThickness="1" Background="{DynamicResource CardBrush}">
                            <StackPanel>
                                <TextBlock Text="Средний чек" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding StatAvgDealText}" FontSize="20" FontWeight="Bold"
                                           Foreground="#42A5F5" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="8" Padding="16" Margin="0,0,8,0"
                                BorderBrush="#AB47BC" BorderThickness="1" Background="{DynamicResource CardBrush}">
                            <StackPanel>
                                <TextBlock Text="Новых клиентов" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding StatNewClients}" FontSize="28" FontWeight="Bold"
                                           Foreground="#AB47BC" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="8" Padding="16"
                                BorderBrush="#FF8F00" BorderThickness="1" Background="{DynamicResource CardBrush}">
                            <StackPanel>
                                <TextBlock Text="Ожидающих записей" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding StatPendingAppts}" FontSize="28" FontWeight="Bold"
                                           Foreground="#FF8F00" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Пирог + Рейтинг риелторов -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Пирог: статусы объектов -->
                        <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Admin.PropsByStatus}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                                <lvc:PieChart Series="{Binding PropStatusSeries}" Height="210" LegendPosition="Bottom"/>
                            </StackPanel>
                        </Border>

                        <!-- Карточный рейтинг риелторов -->
                        <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Рейтинг эффективности" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Рейтинг 35% + Продажи 30% + Записи 20% + Активность 15%"
                                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="6" Padding="14,6"
                                            Background="{Binding TeamAvgColor}" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Среднее по команде: " FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TeamAvgScore}" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="/100" FontSize="11" Foreground="White" VerticalAlignment="Bottom" Margin="2,0,0,1"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding RealtorSummary}" Margin="0,0,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                                                    Padding="12,10" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="46"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="88"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Место -->
                                                    <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19"
                                                            Background="{Binding Color}" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding RankEmoji}" FontSize="14" FontWeight="Bold"
                                                                   Foreground="White" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Имя + балл + тренд + прогресс-бар -->
                                                    <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock Text="{Binding Score}" FontSize="20" FontWeight="Bold"
                                                                       Foreground="{Binding ScoreColor}"/>
                                                            <TextBlock Text="/100" FontSize="11" VerticalAlignment="Bottom"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Margin="2,0,8,2"/>
                                                            <!-- Тренд -->
                                                            <Border Background="{Binding TrendColor}" CornerRadius="4"
                                                                    Padding="5,1" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding TrendArrow}" FontSize="13"
                                                                           FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                            <!-- Прогресс-бар -->
                                                            <Border Background="{DynamicResource BorderBrush}"
                                                                    CornerRadius="3" Height="6" Width="150"
                                                                    VerticalAlignment="Center">
                                                                <Border Background="{Binding ScoreColor}" CornerRadius="3"
                                                                        Height="6" HorizontalAlignment="Left"
                                                                        Width="{Binding ScoreBarWidth}"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Мини-метрики -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <StackPanel Margin="0,0,14,0" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding TotalProps}" FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="объектов" FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,14,0" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding SoldProps}" FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="продано" FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,14,0" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding Rating}" FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="#F4B942" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="рейтинг" FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,14,0" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding CompletedAppt}" FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="визитов" FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,14,0" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding PendingAppt}" FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="#FF8F00" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="в очереди" FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding RevenueText}" FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="#7CB342" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="выручка" FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Кнопка Подробнее -->
                                                    <Button Grid.Column="3" Content="Подробнее"
                                                            Command="{Binding DataContext.SelectRealtorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Height="32" Padding="0" FontSize="12" Cursor="Hand"
                                                            Background="{DynamicResource PrimaryBrush}"
                                                            Foreground="White" BorderThickness="0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Кнопка показать всех / свернуть -->
                                <Button Content="{Binding ShowMoreRealtorsLabel}"
                                        Command="{Binding ToggleShowAllRealtorsCommand}"
                                        Visibility="{Binding ShowMoreRealtorsButton, Converter={StaticResource BoolToVisibility}}"
                                        HorizontalAlignment="Center"
                                        Height="32" Padding="20,0" FontSize="12" Margin="0,4,0,0"
                                        Background="Transparent"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        BorderBrush="{DynamicResource PrimaryBrush}"
                                        BorderThickness="1" Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- График продаж агентства по месяцам -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="📈 Динамика продаж агентства" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="6 мес" Command="{Binding SetChartPeriod6mCommand}"
                                            Height="26" Padding="10,0" FontSize="11" Cursor="Hand" Margin="0,0,4,0">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsChartPeriod6m}" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                    </Button>
                                    <Button Content="1 год" Command="{Binding SetChartPeriod1yCommand}"
                                            Height="26" Padding="10,0" FontSize="11" Cursor="Hand" Margin="0,0,4,0">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsChartPeriod1y}" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                    </Button>
                                    <Button Content="Всё время" Command="{Binding SetChartPeriodAllCommand}"
                                            Height="26" Padding="10,0" FontSize="11" Cursor="Hand">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsChartPeriodAll}" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <lvc:CartesianChart Series="{Binding AgencySalesSeries}"
                                               XAxes="{Binding AgencySalesXAxes}"
                                               Height="170"/>
                        </StackPanel>
                    </Border>

                    <!-- Детальная панель выбранного риелтора -->
                    <Border Visibility="{Binding HasSelectedRealtor, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,14">
                        <StackPanel>

                            <!-- Заголовок + балл -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="{Binding DetailRealtorName}"/>
                                    </TextBlock>
                                    <TextBlock Text="Детальная карточка — объекты за всё время, записи за выбранный период"
                                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="10" Padding="18,8"
                                        Background="{Binding DetailScoreColor}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DetailScore}" FontSize="26" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="/100" FontSize="13" Foreground="White" VerticalAlignment="Bottom" Margin="3,0,0,3"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Вкладки детали -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Обзор" Command="{Binding SetDetailTab0Command}"
                                            Padding="14,8" FontSize="12" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,3"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Padding="14,8" BorderThickness="0,0,0,3"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    Background="{TemplateBinding Background}">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowDetailTab0}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Отзывы" Command="{Binding SetDetailTab1Command}"
                                            Padding="14,8" FontSize="12" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Padding="14,8" BorderThickness="0,0,0,3"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    Background="{TemplateBinding Background}">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowDetailTab1}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Объекты" Command="{Binding SetDetailTab2Command}"
                                            Padding="14,8" FontSize="12" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Padding="14,8" BorderThickness="0,0,0,3"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    Background="{TemplateBinding Background}">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowDetailTab2}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- ── Вкладка 0: Обзор ── -->
                            <StackPanel Visibility="{Binding ShowDetailTab0, Converter={StaticResource BoolToVisibility}}">
                                <UniformGrid Columns="5" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Всего объектов" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DetailTotal}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Активных" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding DetailActive}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Продано" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding DetailSold}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Завершено записей" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DetailCompletedAppt}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Рейтинг" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding DetailRatingText}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- Финансовые показатели риелтора -->
                                <UniformGrid Columns="2" Margin="0,0,0,14">
                                    <Border BorderBrush="#7CB342" BorderThickness="1"
                                            Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                                  Fill="#7CB342"
                                                  Data="M11.8,10.9C9.53,10.31 8.8,9.7 8.8,8.75C8.8,7.66 9.81,6.9 11.5,6.9C13.28,6.9 13.94,7.75 14,9H16.21C16.14,7.28 15.09,5.7 13,5.19V3H10V5.16C8.06,5.58 6.5,6.84 6.5,8.77C6.5,11.08 8.41,12.23 11.2,12.9C13.7,13.5 14.2,14.38 14.2,15.31C14.2,16 13.71,17.1 11.5,17.1C9.44,17.1 8.63,16.18 8.5,15H6.32C6.44,17.19 8.08,18.42 10,18.83V21H13V18.85C14.95,18.5 16.5,17.35 16.5,15.3C16.5,12.46 14.07,11.49 11.8,10.9Z"/>
                                            <StackPanel>
                                                <TextBlock Text="Общая выручка (все продажи)" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding DetailRevenueText}" FontSize="18" FontWeight="Bold" Foreground="#7CB342" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border BorderBrush="#42A5F5" BorderThickness="1"
                                            Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="14,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"
                                                  Fill="#42A5F5"
                                                  Data="M22,21H2V3H4V19H6V10H10V19H12V6H16V19H18V14H22V21Z"/>
                                            <StackPanel>
                                                <TextBlock Text="Средний чек сделки" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding DetailAvgDealText}" FontSize="18" FontWeight="Bold" Foreground="#42A5F5" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Статусы объектов" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                        <lvc:PieChart Series="{Binding DetailStatusSeries}" Height="170" LegendPosition="Bottom"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                        <TextBlock Text="Записи по месяцам (последние 6 мес.)" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                        <lvc:CartesianChart Series="{Binding DetailApptSeries}"
                                                            XAxes="{Binding DetailApptXAxes}" Height="170"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- ── Вкладка 1: Отзывы ── -->
                            <StackPanel Visibility="{Binding ShowDetailTab1, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,20"
                                            Visibility="{Binding NoDetailReviews, Converter={StaticResource BoolToVisibility}}">
                                    <Path Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"/>
                                    <TextBlock Text="Нет одобренных отзывов" FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding DetailReviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                                                    Padding="14,10" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                            Background="{DynamicResource PlaceholderBrush}"
                                                            Margin="0,0,12,0" VerticalAlignment="Top">
                                                        <Path Width="16" Height="16" Stretch="Uniform"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              Fill="{DynamicResource TextSecondaryBrush}"
                                                              Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock Text="{Binding ClientName}" FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding Stars}" FontSize="13"
                                                                       Foreground="{Binding StarColor}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Comment}" FontSize="12"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding Date}" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Top" Margin="10,2,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- ── Вкладка 2: Объекты ── -->
                            <StackPanel Visibility="{Binding ShowDetailTab2, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel HorizontalAlignment="Center" Margin="0,20,0,20"
                                            Visibility="{Binding NoDetailProperties, Converter={StaticResource BoolToVisibility}}">
                                    <Path Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/>
                                    <TextBlock Text="У риелтора нет объектов" FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding DetailProperties}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                                                    Padding="14,10" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding City}" FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Price}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"
                                                               VerticalAlignment="Center" Margin="16,0"/>
                                                    <Border Grid.Column="3" CornerRadius="4" Padding="10,4"
                                                            Background="{Binding StatusColor}" HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StatusLabel}" FontSize="11"
                                                                   FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== ВКЛАДКА 4: РАССЫЛКА ===== -->
            <Grid Visibility="{Binding ShowTab4, Converter={StaticResource BoolToVisibility}}"
                  Margin="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="620" HorizontalAlignment="Center" Margin="0,8,0,40">

                        <!-- Кому -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                Padding="24,18" Margin="0,0,0,14">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Кому отправить" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="Всем пользователям" Command="{Binding MailToAllCommand}"
                                            Height="32" Padding="14,0" FontSize="12" Margin="0,0,8,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MailRecipients}" Value="all">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Клиентам" Command="{Binding MailToClientsCommand}"
                                            Height="32" Padding="14,0" FontSize="12" Margin="0,0,8,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MailRecipients}" Value="clients">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Риелторам" Command="{Binding MailToRealtorsCommand}"
                                            Height="32" Padding="14,0" FontSize="12"
                                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MailRecipients}" Value="realtors">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Шаблоны -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                Padding="24,18" Margin="0,0,0,14">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Шаблоны писем" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="Выберите шаблон — тема и текст заполнятся автоматически"
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="📢 Новые объекты"
                                            Command="{Binding UseTemplateCommand}"
                                            CommandParameter="new_listings"
                                            Height="34" Padding="14,0" FontSize="12" Margin="0,0,8,8"
                                            Background="{DynamicResource PrimaryBrush}" Foreground="White"/>
                                    <Button Content="💸 Снижение цен"
                                            Command="{Binding UseTemplateCommand}"
                                            CommandParameter="price_drop"
                                            Height="34" Padding="14,0" FontSize="12" Margin="0,0,8,8"
                                            Background="#FF8F00" Foreground="White"/>
                                    <Button Content="🏠 Открытые показы"
                                            Command="{Binding UseTemplateCommand}"
                                            CommandParameter="open_showings"
                                            Height="34" Padding="14,0" FontSize="12" Margin="0,0,0,8"
                                            Background="#7CB342" Foreground="White"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Предпросмотр письма (всегда виден) -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                Padding="24,18" Margin="0,0,0,14">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Data="M20,4H4C2.9,4 2,4.9 2,6V18C2,19.1 2.9,20 4,20H20C21.1,20 22,19.1 22,18V6C22,4.9 21.1,4 20,4ZM20,8L12,13L4,8V6L12,11L20,6V8Z"/>
                                    <TextBlock Text="Предпросмотр письма" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="6"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Padding="16,12">
                                    <StackPanel>
                                        <TextBlock FontSize="14" FontWeight="Bold" Margin="0,0,0,8" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding MailSubject}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MailSubject}" Value="">
                                                            <Setter Property="Text" Value="Тема письма появится здесь..."/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="12" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding MailBody}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MailBody}" Value="">
                                                            <Setter Property="Text" Value="Текст письма появится здесь после выбора шаблона или ввода вручную."/>
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Письмо -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                Padding="24,18" Margin="0,0,0,14">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Содержание письма" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                                <TextBlock Text="Тема письма" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding MailSubject, UpdateSourceTrigger=PropertyChanged}"
                                         Height="36" Padding="5,0" Margin="0,0,0,14"
                                         FontSize="13"/>

                                <TextBlock Text="Текст письма" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding MailBody, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="120" Padding="10,8" FontSize="13"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalContentAlignment="Top" Margin="0,0,0,16"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Результат -->
                                    <TextBlock Grid.Column="0" Text="{Binding MailResult}"
                                               VerticalAlignment="Center" FontSize="13"
                                               TextWrapping="Wrap" Margin="0,0,12,0"
                                               Visibility="{Binding MailResult, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MailSuccess}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MailSuccess}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Grid.Column="1" Content="Отправить"
                                            Command="{Binding SendMailCommand}"
                                            Height="40" Padding="24,0" FontSize="13"
                                            Background="{DynamicResource PrimaryBrush}"
                                            Foreground="White" BorderThickness="0"/>
                                </Grid>
                            </StackPanel>
                        </Border>


                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ===== ВКЛАДКА 3: МОЙ ПРОФИЛЬ ===== -->
            <ScrollViewer Visibility="{Binding ShowTab3, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto">
                <Grid Margin="24,24,24,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Аватар -->
                    <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="28,20">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="90" Height="90" CornerRadius="45" ClipToBounds="True"
                                    Background="{DynamicResource PlaceholderBrush}" Margin="0,0,0,10">
                                <Grid>
                                    <Path Width="40" Height="40" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Visibility="{Binding ProfileAvatar, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}"
                                          Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                    <Image Source="{Binding ProfileAvatar, Converter={StaticResource ByteArrayToImage}}" Stretch="UniformToFill"
                                           Visibility="{Binding ProfileAvatar, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding ProfileLogin}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Администратор" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Загрузить фото" Command="{Binding UploadProfileAvatarCommand}"
                                        Height="30" Padding="14,0" FontSize="12" Margin="0,0,8,0"
                                        Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                                <Button Content="Удалить" Command="{Binding RemoveProfileAvatarCommand}"
                                        Height="30" Padding="14,0" FontSize="12"
                                        Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Visibility="{Binding ProfileAvatar, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Две колонки: личные данные | смена пароля -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Личные данные -->
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="28,24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="14" ShadowDepth="2" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Личные данные" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,22"/>
                                <TextBlock Text="Имя и фамилия" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfileFullName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="E-mail" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfileEmail, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Телефон" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfilePhone, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,22"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <Button Content="💾 Сохранить профиль" Command="{Binding SaveProfileCommand}"
                                        Height="44" FontSize="14" FontWeight="SemiBold"
                                        Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                                <TextBlock Margin="0,12,0,0" FontSize="13" TextWrapping="Wrap"
                                           Text="{Binding ProfileResult}"
                                           Visibility="{Binding ProfileResult, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProfileSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ProfileSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Смена пароля -->
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="28,24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="14" ShadowDepth="2" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Смена пароля" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,22"/>
                                <TextBlock Text="Текущий пароль" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding ProfileOldPassword, Mode=TwoWay}"
                                             Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Новый пароль" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding ProfileNewPassword, Mode=TwoWay}"
                                             Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Повторите пароль" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding ProfileConfirmPassword, Mode=TwoWay}"
                                             Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,22"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <Button Content="Изменить пароль" Command="{Binding ChangeProfilePasswordCommand}"
                                        Height="44" FontSize="14" FontWeight="SemiBold"
                                        Background="Transparent"
                                        Foreground="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"/>
                                <TextBlock Margin="0,12,0,0" FontSize="13" TextWrapping="Wrap"
                                           Text="{Binding PasswordResult}"
                                           Visibility="{Binding PasswordResult, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PasswordSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PasswordSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>



