<UserControl x:Class="MSM.Views.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:MSM.Helpers"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Margin="0,70,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

<Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="16,0">
                
                <Button Content="{DynamicResource Nav.MyProfile}"
                        Command="{Binding SetTab3Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab3}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Admin.Users}"
                        Command="{Binding SetTab0Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab0}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding SetTab1Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Admin.Reviews}" VerticalAlignment="Center"/>
                            <Border Background="#EF5350" CornerRadius="10" Padding="5,1" Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding PendingReviewsCount, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding PendingReviewsCount}" FontSize="10"
                                           Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button.Content>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab1}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Admin.Stats}"
                        Command="{Binding SetTab2Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab2}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Admin.Mailings}"
                        Command="{Binding SetTab4Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab4}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Admin.Properties}"
                        Command="{Binding SetTab5Command}"
                        Background="Transparent" BorderThickness="0,0,0,3" Padding="12,0"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab5}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

<Grid Grid.Row="1">

<Grid Visibility="{Binding ShowTab0, Converter={StaticResource BoolToVisibility}}"
                  Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

<Border Grid.Row="0" CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                        Visibility="{Binding UserActionMessage, Converter={StaticResource BoolToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding UserActionMessage}" FontSize="13"
                               Foreground="White" FontWeight="SemiBold"/>
                </Border>

<Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding UserSearch, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" FontSize="13" Padding="10,0"
                             Background="{DynamicResource InputBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <Button Grid.Column="1" Content="{DynamicResource Common.Search}"
                            Command="{Binding SearchUsersCommand}"
                            Height="36" Margin="8,0,0,0" FontSize="12"
                            Background="{DynamicResource PrimaryBrush}"
                            Foreground="White" BorderThickness="0"/>
                </Grid>

<StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="{DynamicResource Admin.FilterAll}" Command="{Binding FilterAllCommand}"
                            Height="28" Padding="14,0" FontSize="12" Margin="0,0,6,0"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserRoleFilter}" Value="all">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource Admin.FilterRealtors}" Command="{Binding FilterRealtorCommand}"
                            Height="28" Padding="14,0" FontSize="12" Margin="0,0,6,0"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserRoleFilter}" Value="realtor">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource Admin.FilterClients}" Command="{Binding FilterClientCommand}"
                            Height="28" Padding="14,0" FontSize="12" Margin="0,0,6,0"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserRoleFilter}" Value="client">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource Admin.FilterBlocked}" Command="{Binding FilterBlockedCommand}"
                            Height="28" Padding="14,0" FontSize="12"
                            BorderThickness="1" BorderBrush="#EF5350">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="#EF5350"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserRoleFilter}" Value="blocked">
                                        <Setter Property="Background" Value="#EF5350"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

<DataGrid Grid.Row="3" ItemsSource="{Binding Users}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False"
                          Background="{DynamicResource SurfaceBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          RowBackground="{DynamicResource SurfaceBrush}"
                          AlternatingRowBackground="{DynamicResource BackgroundBrush}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource SeparatorBrush}"
                          HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="8,6"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Имя" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" VerticalAlignment="Center"/>
                                        <Border Background="#EF5350" CornerRadius="3" Padding="4,1"
                                                Margin="6,0,0,0"
                                                Visibility="{Binding ShowBlockedBadge, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{DynamicResource Admin.BannedBadge}" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Логин"   Binding="{Binding Login}"       Width="110"/>
                        <DataGridTextColumn Header="E-mail"  Binding="{Binding Email}"       Width="160"/>
                        <DataGridTextColumn Header="Роль"    Binding="{Binding RoleDisplay}" Width="100"/>
                        <DataGridTextColumn Header="Создан"  Binding="{Binding CreatedAt}"   Width="90"/>
                        <DataGridTemplateColumn Header="Действия" Width="230">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <Button Content="{DynamicResource Admin.Promote}"
                                                Command="{Binding DataContext.PromoteToRealtorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}"
                                                Visibility="{Binding CanPromote, Converter={StaticResource BoolToVisibility}}"
                                                Height="26" Padding="8,0" FontSize="11"
                                                Background="{DynamicResource PrimaryBrush}"
                                                Foreground="White" BorderThickness="0" Margin="0,0,4,0"/>
                                        <Button Content="{DynamicResource Admin.Demote}"
                                                Command="{Binding DataContext.DemoteToClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}"
                                                Visibility="{Binding CanDemote, Converter={StaticResource BoolToVisibility}}"
                                                Height="26" Padding="8,0" FontSize="11"
                                                Background="#FF8F00"
                                                Foreground="White" BorderThickness="0" Margin="0,0,4,0"/>
                                        <Button Content="{Binding BlockLabel}"
                                                Command="{Binding DataContext.ToggleBlockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}"
                                                Height="26" Padding="8,0" FontSize="11"
                                                BorderThickness="1" BorderBrush="#EF5350"
                                                Background="Transparent" Foreground="#EF5350"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

<Grid Visibility="{Binding ShowTab1, Converter={StaticResource BoolToVisibility}}"
                  Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

<Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Admin.ReviewRealtorLabel}" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <ComboBox SelectedItem="{Binding ReviewRealtorFilter, Mode=TwoWay}"
                                  ItemsSource="{Binding ReviewRealtorNames}"
                                  Width="240" Height="30"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="">
                                                        <Setter Property="Text" Value="{DynamicResource Admin.AllRealtors}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding NoReviews, Converter={StaticResource BoolToVisibility}}">
                    <Path Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center"
                          Fill="{DynamicResource TextSecondaryBrush}"
                          Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"/>
                    <TextBlock Text="{DynamicResource Admin.NoReviews}" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PendingReviews}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                        Padding="16,12" Margin="0,0,0,8">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="4" ShadowDepth="1" Opacity="0.08"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Author}" FontWeight="SemiBold"
                                                           FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Rating}" FontSize="13"
                                                           Foreground="{DynamicResource PrimaryBrush}" Margin="12,0,0,0"/>
                                                <TextBlock Text="{Binding Date}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Comment}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="{DynamicResource Admin.Approve}"
                                                    Command="{Binding DataContext.ApproveReviewCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Height="32" Padding="12,0" FontSize="12" Margin="0,0,8,0"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    Foreground="White" BorderThickness="0"/>
                                            <Button Content="{DynamicResource Admin.Reject}"
                                                    Command="{Binding DataContext.RejectReviewCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Height="32" Padding="12,0" FontSize="12"
                                                    Background="{DynamicResource ErrorBrush}"
                                                    Foreground="White" BorderThickness="0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

<ScrollViewer Visibility="{Binding ShowTab2, Converter={StaticResource BoolToVisibility}}"
                          Margin="16" VerticalScrollBarVisibility="Auto">
                <StackPanel>

<Border Visibility="{Binding HasAlerts, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Padding="0" Margin="0,0,0,14">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>
                        <StackPanel>
                            
                            <Border Background="#EF5350" CornerRadius="8,8,0,0" Padding="16,10" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleAlertsExpandedCommand}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⚠" FontSize="14" Foreground="White" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Admin.Alerts}" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        
                                        <Border Background="#33FFFFFF" CornerRadius="10" Padding="10,2" Margin="0,0,10,0">
                                            <TextBlock FontSize="12" FontWeight="Bold" Foreground="White">
                                                <Run Text="{Binding Alerts.Count, Mode=OneWay}"/>
                                                <Run Text="/"/>
                                                <Run Text="{Binding AllAlertsCount, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>
                                        
                                        <TextBlock FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="▲"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAlertsExpanded}" Value="False">
                                                            <Setter Property="Text" Value="▼"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

<Border Visibility="{Binding IsAlertsExpanded, Converter={StaticResource BoolToVisibility}}"
                                    Background="{DynamicResource SurfaceBrush}" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

<StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Button Content="{DynamicResource Alert.SeverityAll}" Command="{Binding FilterAlertAllCommand}" Height="26" Padding="12,0" FontSize="11" Margin="0,0,4,0" Cursor="Hand">
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsAlertAll}" Value="True"><Setter Property="Background" Value="#EF5350"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                        </Button>
                                        <Button Content="{DynamicResource Alert.SeverityInfo}"     Command="{Binding FilterAlertInfoCommand}"     Height="26" Padding="12,0" FontSize="11" Margin="0,0,4,0" Cursor="Hand">
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsAlertInfo}" Value="True"><Setter Property="Background" Value="#9E9E9E"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                        </Button>
