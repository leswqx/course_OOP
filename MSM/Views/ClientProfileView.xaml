<UserControl x:Class="MSM.Views.ClientProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MSM.Helpers"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="{DynamicResource Common.Back}"
                        Command="{Binding GoBackCommand}"
                        Height="32" Padding="12,0" FontSize="13"
                        Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                <TextBlock Grid.Column="1" Text="{DynamicResource ClientProfile.Title}"
                           FontSize="17" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding ThemeIcon}"
                            Command="{Binding ToggleThemeCommand}"
                            Width="32" Height="32" Margin="0,0,6,0" FontSize="16"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                    <Button Content="{Binding LanguageIcon}"
                            Command="{Binding ToggleLanguageCommand}"
                            Width="36" Height="32" FontSize="12" FontWeight="SemiBold"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="560" HorizontalAlignment="Center" Margin="0,32,0,40">

                <!-- Аватар + логин -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="32,24" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="12" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">

                        <!-- Аватар -->
                        <Border Width="100" Height="100" CornerRadius="50"
                                BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2"
                                HorizontalAlignment="Center" Margin="0,0,0,12">
                            <Border.Clip>
                                <EllipseGeometry Center="50,50" RadiusX="50" RadiusY="50"/>
                            </Border.Clip>
                            <Grid>
                                <!-- Аватар из базы -->
                                <Image Source="{Binding AvatarPhoto, Converter={StaticResource ByteArrayToImage}}"
                                       Stretch="UniformToFill"/>
                                <!-- Placeholder если нет фото -->
                                <TextBlock Text="👤" FontSize="48"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AvatarPhoto}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Кнопки аватара -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Button Content="{DynamicResource ClientProfile.UploadPhoto}"
                                    Command="{Binding UploadAvatarCommand}"
                                    Height="30" Padding="12,0" FontSize="12" Margin="0,0,8,0"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Foreground="White" BorderThickness="0"/>
                            <Button Content="{DynamicResource ClientProfile.RemovePhoto}"
                                    Command="{Binding RemoveAvatarCommand}"
                                    Height="30" Padding="12,0" FontSize="12"
                                    Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                        </StackPanel>

                        <!-- Логин (не редактируемый) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource ClientProfile.Login}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Login}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Личные данные -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="32,24" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="12" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource ClientProfile.PersonalData}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="{DynamicResource ClientProfile.FullName}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Height="40" FontSize="14" Padding="12,0" Margin="0,0,0,16"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                        <TextBlock Text="{DynamicResource ClientProfile.Email}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Height="40" FontSize="14" Padding="12,0" Margin="0,0,0,16"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                        <TextBlock Text="{DynamicResource ClientProfile.Phone}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Height="40" FontSize="14" Padding="12,0" Margin="0,0,0,20"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                        <!-- Сообщение о результате -->
                        <TextBlock Text="{Binding ProfileResult}" FontSize="13" Margin="0,0,0,12"
                                   Visibility="{Binding HasProfileResult, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#EF5350"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProfileSuccess}" Value="True">
                                            <Setter Property="Foreground" Value="#7CB342"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Content="{DynamicResource ClientProfile.Save}"
                                Command="{Binding SaveProfileCommand}"
                                Height="42" FontSize="14" FontWeight="SemiBold"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- Смена пароля -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="32,24">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="12" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource ClientProfile.ChangePassword}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="{DynamicResource ClientProfile.OldPassword}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                     helpers:PasswordBoxHelper.BoundPassword="{Binding OldPassword, Mode=TwoWay}"
                                     Height="40" FontSize="14" Padding="12,0" Margin="0,0,0,16"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                        <TextBlock Text="{DynamicResource ClientProfile.NewPassword}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                     helpers:PasswordBoxHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay}"
                                     Height="40" FontSize="14" Padding="12,0" Margin="0,0,0,16"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                        <TextBlock Text="{DynamicResource ClientProfile.ConfirmPassword}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                     helpers:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"
                                     Height="40" FontSize="14" Padding="12,0" Margin="0,0,0,20"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                        <!-- Сообщение о результате смены пароля -->
                        <TextBlock Text="{Binding PasswordResult}" FontSize="13" Margin="0,0,0,12"
                                   Visibility="{Binding HasPasswordResult, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#EF5350"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PasswordSuccess}" Value="True">
                                            <Setter Property="Foreground" Value="#7CB342"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Content="{DynamicResource ClientProfile.ChangePasswordBtn}"
                                Command="{Binding ChangePasswordCommand}"
                                Height="42" FontSize="14" FontWeight="SemiBold"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
