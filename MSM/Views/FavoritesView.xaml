<!-- ReSharper disable all -->
<UserControl x:Class="MSM.Views.FavoritesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MSM.Controls"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="0,70,0,0">

        <!-- Заголовок страницы -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Favorites.Title}"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="20,20,20,4"/>

        <Grid Grid.Row="1">
            <TextBlock Text="{DynamicResource Common.Loading}" HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <TextBlock Text="{Binding ErrorMessage}" HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                       Margin="20,0"
                       Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibility}}"/>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <Path Width="52" Height="52" Stretch="Uniform" HorizontalAlignment="Center"
                      Fill="{DynamicResource TextSecondaryBrush}"
                      Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"/>
                <TextBlock Text="{DynamicResource Favorites.Empty}" FontSize="16"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,16"/>
                <Button Content="{DynamicResource Nav.Catalog}"
                        Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Center"
                        Height="40" Padding="24,0" FontSize="14"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsContentVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Properties}" Margin="12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <controls:PropertyCardControl>
                                        <controls:PropertyCardControl.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </controls:PropertyCardControl.InputBindings>
                                    </controls:PropertyCardControl>
                                    <!-- Оверлей для скрытых объектов -->
                                    <Border Panel.ZIndex="3" CornerRadius="12" Margin="8"
                                            Background="#AA111111" Cursor="Arrow"
                                            Visibility="{Binding IsHidden, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource Favorites.Hidden}" Foreground="White"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource Favorites.HiddenDesc}" Foreground="#BBFFFFFF"
                                                       FontSize="11" HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Плавающая кнопка убрать из избранного -->
                                    <Button Panel.ZIndex="5"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,12,12,0" Width="28" Height="28" Cursor="Hand"
                                            Command="{Binding DataContext.RemoveFromFavoritesCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Favorites.Remove}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#BB000000" CornerRadius="14">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#EF5350"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="✕" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Command="{Binding ShowMoreCommand}"
                            Visibility="{Binding CanShowMore, Converter={StaticResource BoolToVisibility}}"
                            HorizontalAlignment="Center" Margin="0,4,0,20"
                            Height="40" Padding="24,0" FontSize="13"
                            Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Button.Content>
                            <TextBlock>
                                <Run Text="{DynamicResource Catalog.ShowMorePrefix}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding ShowMoreCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource Catalog.ShowMoreSuffix}"/>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
