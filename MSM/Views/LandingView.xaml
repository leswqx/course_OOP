<UserControl x:Class="MSM.Views.LandingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="590" d:DesignWidth="1000">

    <Grid Focusable="False">
        <!-- Фоновое фото -->
        <Rectangle>
            <Rectangle.Fill>
                <ImageBrush ImageSource="/Resources/Images/main.png" Stretch="UniformToFill"/>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Градиентный оверлей -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#78000000" Offset="0"/>
                    <GradientStop Color="#42000000" Offset="0.5"/>
                    <GradientStop Color="#62000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Герой-контент -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch"
                    MaxWidth="1000" Margin="24,0">

            <!-- Заголовок -->
            <TextBlock Text="Найдите дом своей мечты"
                       FontSize="58" FontWeight="Bold" Foreground="White"
                       TextAlignment="Center" TextWrapping="Wrap"
                       LineHeight="68" Margin="0,0,0,14"/>

            <!-- Подзаголовок -->
            <TextBlock Text="Квартиры, дома и коммерческая недвижимость — поможем найти идеальный вариант."
                       FontSize="17" Foreground="#CCFFFFFF"
                       TextAlignment="Center" TextWrapping="Wrap"
                       LineHeight="26" Margin="0,0,0,32"/>

            <!-- Поисковая панель -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="900"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поля поиска -->
                <Border Grid.Column="0" Background="White" CornerRadius="14" Height="62">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="28" ShadowDepth="4"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Тип объекта -->
                        <ComboBox Grid.Column="0"
                                  Style="{StaticResource TransparentComboBox}"
                                  ItemsSource="{Binding PropertyTypes}"
                                  SelectedItem="{Binding SelectedPropertyType}"
                                  Margin="20,0"/>

                        <Rectangle Grid.Column="1" Fill="#E0E0E0" Margin="0,16"/>

                        <!-- Комнат -->
                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource TransparentComboBox}"
                                  ItemsSource="{Binding RoomOptions}"
                                  SelectedItem="{Binding SelectedRooms}"
                                  Margin="20,0"/>

                        <Rectangle Grid.Column="3" Fill="#E0E0E0" Margin="0,16"/>

                        <!-- Цена до (с плейсхолдером) -->
                        <Grid Grid.Column="4" Margin="20,0">
                            <TextBox Text="{Binding MaxPrice, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     FontSize="15" Foreground="#222"
                                     HorizontalContentAlignment="Left"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Text="Цена до, BYN"
                                       IsHitTestVisible="False"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       Foreground="Black" Opacity="0.60" FontSize="15">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MaxPrice}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Кнопка Показать объекты (отдельная) -->
                <Button Grid.Column="2" Command="{Binding ShowPropertiesCommand}" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#3A7D4F"
                                                CornerRadius="14" Padding="36,0" Height="62">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="28" ShadowDepth="4"/>
                                            </Border.Effect>
                                            <TextBlock Text="Показать объекты"
                                                       Foreground="White" FontSize="15" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#4A9061"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2D6340"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Популярные запросы -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                <TextBlock Text="Популярное:" Foreground="#80FFFFFF" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Command="{Binding SetTagSearchCommand}" CommandParameter="apartment_2k"
                        Cursor="Hand" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#20FFFFFF" CornerRadius="20" Padding="16,6">
                                            <TextBlock Text="Квартира 2к" Foreground="White" FontSize="13"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#38FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding SetTagSearchCommand}" CommandParameter="apartment_new"
                        Cursor="Hand" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#20FFFFFF" CornerRadius="20" Padding="16,6">
                                            <TextBlock Text="Новостройки" Foreground="White" FontSize="13"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#38FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding SetTagSearchCommand}" CommandParameter="house"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#20FFFFFF" CornerRadius="20" Padding="16,6">
                                            <TextBlock Text="Дом с участком" Foreground="White" FontSize="13"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#38FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Статистика снизу -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"
                    HorizontalAlignment="Center" Margin="0,0,0,28">
            <StackPanel HorizontalAlignment="Center" Margin="36,0">
                <TextBlock Text="500+" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Объектов в каталоге" FontSize="12" Foreground="#70FFFFFF" HorizontalAlignment="Center"/>
            </StackPanel>
            <Rectangle Width="1" Height="32" Fill="#28FFFFFF" Margin="0,6"/>
            <StackPanel HorizontalAlignment="Center" Margin="36,0">
                <TextBlock Text="150+" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Довольных клиентов" FontSize="12" Foreground="#70FFFFFF" HorizontalAlignment="Center"/>
            </StackPanel>
            <Rectangle Width="1" Height="32" Fill="#28FFFFFF" Margin="0,6"/>
            <StackPanel HorizontalAlignment="Center" Margin="36,0">
                <TextBlock Text="10+" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Опытных риелторов" FontSize="12" Foreground="#70FFFFFF" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>

