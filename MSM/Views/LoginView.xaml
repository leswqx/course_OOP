<UserControl x:Class="MSM.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:MSM.Helpers"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="600" d:DesignWidth="900"
             >
    

    <Grid Margin="0,70,0,0">
        <!-- Центрированная карточка формы -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="400"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="18"
                Padding="44,40">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.13"
                                  BlurRadius="36" ShadowDepth="6"/>
            </Border.Effect>

            <StackPanel>
                <!-- Название -->
                <TextBlock Text="{DynamicResource App.Title}"
                           FontSize="19" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,4"/>

                <!-- Подзаголовок -->
                <TextBlock Text="{DynamicResource Login.Subtitle}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,28"/>

                <!-- Логин -->
                <TextBlock Text="{DynamicResource Login.LoginLabel}"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         Height="42" Padding="5,0,0,0" FontSize="14" Margin="0,0,0,16"
                         Foreground="#111111" Background="White" CaretBrush="#111111"/>

                <!-- Пароль -->
                <TextBlock Text="{DynamicResource Login.PasswordLabel}"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                             helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="42" Padding="5,0,0,0" FontSize="14" Margin="0,0,0,8"
                             Foreground="#111111" Background="White" CaretBrush="#111111"/>

                <!-- Ошибка -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource ErrorBrush}"
                           Margin="0,0,0,14"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Войти -->
                <Button Content="{DynamicResource Login.SignIn}"
                        Command="{Binding LoginCommand}"
                        Height="42" FontSize="16" Margin="0,0,0,10"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"/>

                <!-- Зарегистрироваться -->
                <Button Content="{DynamicResource Login.Register}"
                        Command="{Binding NavigateToRegisterCommand}"
                        Height="40" FontSize="14"
                        Background="Transparent"
                        Foreground="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
