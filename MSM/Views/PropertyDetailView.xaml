<UserControl x:Class="MSM.Views.PropertyDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MSM.Controls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Margin="0,70,0,0">
        <!-- ===== КОНТЕНТ ===== -->
        <Grid>

            <TextBlock Text="{DynamicResource Common.Loading}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="{DynamicResource ErrorBrush}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="580"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ===== ЛЕВАЯ: Карусель ===== -->
                    <controls:ImageCarouselControl Grid.Column="0" Grid.Row="0"
                                                   Height="520" Margin="0,0,16,0"/>

                    <!-- ===== ПРАВАЯ: Информация + действия ===== -->
                    <StackPanel Grid.Column="1" Grid.Row="0">

                        <!-- Бейдж типа + статус -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="4"
                                    Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding PropertyTypeDisplay}"
                                           Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                            <Border Background="{DynamicResource BadgePlaceholderBrush}" CornerRadius="4" Padding="10,4">
                                <TextBlock Text="{Binding StatusDisplay}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            </Border>
                        </StackPanel>

                        <!-- Цена -->
                        <TextBlock Text="{Binding Property.Price, Converter={StaticResource PriceToString}}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8"/>

                        <!-- Название -->
                        <TextBlock Text="{Binding Property.Title}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,16"/>

                        <!-- Параметры -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                Padding="14,12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource Detail.Area}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               Margin="0,0,0,2"/>
                                    <TextBlock FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="{Binding Property.Area, StringFormat='{}{0:F0} м²'}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource Detail.Rooms}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding Property.Rooms}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12"
                                            Visibility="{Binding Property.Bathrooms, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{DynamicResource Detail.Bathrooms}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               Margin="0,0,0,2"/>
                                    <TextBlock FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="Property.Bathrooms" TargetNullValue="—"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource Detail.Floor}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding FloorInfo}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource Detail.YearBuilt}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               Margin="0,0,0,2"/>
                                    <TextBlock FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="Property.YearBuilt" TargetNullValue="—"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="{DynamicResource Detail.Renovation}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               Margin="0,0,0,2"/>
                                    <TextBlock FontSize="15" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Property.HasRepair}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource Common.Yes}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Property.HasRepair}" Value="False">
                                                        <Setter Property="Text" Value="{DynamicResource Common.No}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <TextBlock Text="{DynamicResource Detail.Mortgage}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               Margin="0,0,0,2"/>
                                    <TextBlock FontSize="15" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Property.MortgageAvailable}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource Common.Available}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Property.MortgageAvailable}" Value="False">
                                                        <Setter Property="Text" Value="{DynamicResource Common.No}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Адрес -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                Padding="14,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Detail.Address}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                           Margin="0,0,0,4"/>
                                <TextBlock FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="{Binding Property.City}"/>
                                    <Run Text=","/>
                                    <Run Text="{Binding Property.Address}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Риелтор -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                Padding="14,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Detail.Realtor}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Property.Realtor.FullName}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Property.Realtor.Phone}"
                                           FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <!-- Профиль риелтора -->
                        <Button Content="{DynamicResource Detail.RealtorProfile}"
                                Command="{Binding GoToRealtorProfileCommand}"
                                HorizontalAlignment="Left"
                                Height="30" Padding="14,0" FontSize="12" Margin="0,0,0,12"
                                Background="Transparent"
                                Foreground="{DynamicResource PrimaryBrush}"
                                BorderBrush="{DynamicResource PrimaryBrush}"
                                BorderThickness="1"/>

                        <!-- Кнопки: только для клиента -->
                        <StackPanel Visibility="{Binding IsClient, Converter={StaticResource BoolToVisibility}}">

                            <!-- В избранное -->
                            <Button Content="{Binding FavoriteButtonText}"
                                    Command="{Binding ToggleFavoriteCommand}"
                                    Height="40" FontSize="14"
                                    Background="{DynamicResource ButtonSecondaryBg}"
                                    Foreground="{DynamicResource AccentBrush}"
                                    BorderBrush="{DynamicResource PrimaryBrush}"
                                    BorderThickness="1" Margin="0,0,0,8"/>

                            <!-- Записаться на просмотр -->
                            <Button Content="{DynamicResource Detail.Schedule}"
                                    Command="{Binding OpenBookingCalendarCommand}"
                                    Visibility="{Binding IsBookable, Converter={StaticResource BoolToVisibility}}"
                                    Height="40" FontSize="14"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Foreground="White" BorderThickness="0"/>

                            <!-- Бейдж "Продан" -->
                            <Border Visibility="{Binding IsBookable, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}"
                                    Background="#EF5350" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                                <TextBlock Text="🏷 Объект продан — запись недоступна"
                                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                                           TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- ===== ОПИСАНИЕ (вся ширина) ===== -->
                    <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,20,0,0" >
                        <TextBlock Text="{DynamicResource Detail.Description}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16">
                            <TextBlock Text="{Binding Property.Description}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" LineHeight="22"/>
                        </Border>
                    </StackPanel>

                    <!-- ===== ИСТОРИЯ ЦЕН (вся ширина) ===== -->
                    <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,24,0,16"
                                Visibility="{Binding HasPriceHistory, Converter={StaticResource BoolToVisibility}}">

                        <TextBlock Text="{DynamicResource Detail.PriceHistory}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <!-- График -->
                        <lvc:CartesianChart Series="{Binding PriceHistorySeries}"
                                            XAxes="{Binding PriceHistoryXAxes}"
                                            Height="180" Margin="0,0,0,6"
                                            Visibility="{Binding HasPriceChart, Converter={StaticResource BoolToVisibility}}"/>


                        <!-- Таблица -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <ItemsControl ItemsSource="{Binding PriceHistoryRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="16,10,16,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Date}"
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Change}"
                                                       FontSize="12"
                                                       Foreground="{Binding ChangeColor, Converter={StaticResource StringToBrush}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Price}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ===== ЛАЙТБОКС ФОТО ===== -->
        <Grid Visibility="{Binding IsPhotoViewerOpen, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="200">
            <Border Background="#DD000000"/>
            <Image Source="{Binding FullScreenImage}" Stretch="Uniform" Margin="60"/>
            <Button Content="✕" Command="{Binding ClosePhotoViewerCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,16,16,0" Width="44" Height="44"
                    Background="#88000000" Foreground="White"
                    BorderThickness="0" FontSize="20" Cursor="Hand"/>
        </Grid>

        <!-- ===== МОДАЛЬНЫЙ КАЛЕНДАРЬ ЗАПИСИ ===== -->
        <Grid Visibility="{Binding ShowBookingCalendar, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="100">
            <Border Background="#A8000000"/>
            <Border Background="{DynamicResource CardBrush}" CornerRadius="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="520" Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Заголовок -->
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="14,14,0,0" Padding="20,14">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="‹" Command="{Binding BookCalPrevCommand}"
                                        Width="30" Height="30" Cursor="Hand"
                                        Background="Transparent" Foreground="White"
                                        BorderThickness="1" BorderBrush="#60FFFFFF"
                                        FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding BookCalMonthLabel}"
                                           FontSize="15" FontWeight="Bold" Foreground="White"
                                           VerticalAlignment="Center" Margin="14,0"/>
                                <Button Content="›" Command="{Binding BookCalNextCommand}"
                                        Width="30" Height="30" Cursor="Hand"
                                        Background="Transparent" Foreground="White"
                                        BorderThickness="1" BorderBrush="#60FFFFFF"
                                        FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <Button Content="✕" Command="{Binding CloseBookingCalendarCommand}"
                                    HorizontalAlignment="Right" Width="30" Height="30"
                                    Cursor="Hand" Background="Transparent" Foreground="White"
                                    BorderThickness="0" FontSize="16"/>
                        </Grid>
                    </Border>

                    <StackPanel Margin="20,16,20,0">
                        <!-- Дни недели -->
                        <UniformGrid Columns="7" Margin="0,0,0,4">
                            <TextBlock Text="Пн" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Вт" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Ср" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Чт" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Пт" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Сб" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#EF5350"/>
                            <TextBlock Text="Вс" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#EF5350"/>
                        </UniformGrid>

                        <!-- Ячейки календаря -->
                        <ItemsControl ItemsSource="{Binding BookCalDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectBookDayCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="2" Height="44" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="8">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Day}" FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Цветная точка доступности -->
                                            <Border Width="22" Height="5" CornerRadius="3"
                                                    Background="{Binding DotColor}" Margin="0,2,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Легенда -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,12">
                            <Border Width="12" Height="5" CornerRadius="3" Background="#7CB342" Margin="0,0,4,0"/>
                            <TextBlock Text="Доступно" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,0"/>
                            <Border Width="12" Height="5" CornerRadius="3" Background="#EF5350" Margin="0,0,4,0"/>
                            <TextBlock Text="Занято" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,0"/>
                            <Border Width="12" Height="5" CornerRadius="3" Background="#42A5F5" Margin="0,0,4,0"/>
                            <TextBlock Text="Выбрано" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Слоты выбранного дня -->
                    <Border Visibility="{Binding BookDaySelected, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource SurfaceBrush}" Padding="20,14">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10">
                                <Run Text="Слоты на "/>
                                <Run Text="{Binding BookSelectedDateLabel, Mode=OneWay}"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding BookSlots}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Time}"
                                                Command="{Binding DataContext.SelectBookSlotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Time}"
                                                IsEnabled="{Binding IsAvailable}"
                                                Width="64" Height="34" Margin="0,0,6,6"
                                                FontSize="12" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Форма подтверждения -->
                    <Border Visibility="{Binding BookSlotSelected, Converter={StaticResource BoolToVisibility}}"
                            Padding="20,12,20,0">
                        <StackPanel>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4">
                                <Run Text="{DynamicResource Schedule.Comment}"/>
                            </TextBlock>
                            <TextBox Text="{Binding ScheduleComment, UpdateSourceTrigger=PropertyChanged}"
                                     Height="52" Padding="8,6" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalContentAlignment="Top"
                                     Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <Border Padding="20,10,20,20">
                        <StackPanel>
                            <Button Content="{DynamicResource Schedule.Submit}"
                                    Command="{Binding SubmitAppointmentCommand}"
                                    Visibility="{Binding BookSlotSelected, Converter={StaticResource BoolToVisibility}}"
                                    Height="40" FontSize="14" Margin="0,0,0,8"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Foreground="White" BorderThickness="0"/>
                            <TextBlock Text="{DynamicResource Schedule.Success}"
                                       Foreground="{DynamicResource SuccessBrush}" FontSize="13"
                                       Visibility="{Binding ScheduleSuccess, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{DynamicResource Schedule.SlotTaken}"
                                       Foreground="{DynamicResource ErrorBrush}" FontSize="13"
                                       Visibility="{Binding ScheduleSlotTaken, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding ScheduleErrorText}"
                                       Foreground="{DynamicResource ErrorBrush}" FontSize="13"
                                       Visibility="{Binding ScheduleErrorText, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>

