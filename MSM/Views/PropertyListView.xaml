<UserControl x:Class="MSM.Views.PropertyListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MSM.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== ШАПКА ===== -->
        <Border Grid.Row="0" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="6" ShadowDepth="1" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип и название -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🏠" FontSize="28" VerticalAlignment="Center"/>
                    <TextBlock Text="Агентство недвижимости"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#4A4A4A"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Поиск -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Width="320" Height="36"
                             FontSize="14"
                             Padding="10,0"
                             VerticalContentAlignment="Center"/>
                    <Button Content="Найти"
                            Command="{Binding LoadPropertiesCommand}"
                            Height="36" Width="80"
                            FontSize="13"
                            Margin="8,0,0,0"
                            Background="#D4A5A5"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>

                <!-- Пользователь + выход -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{Binding UserFullName}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#4A4A4A" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding UserRoleDisplay}"
                                   FontSize="11" Foreground="#7A7A7A"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Button Content="Выйти"
                            Command="{Binding LogoutCommand}"
                            Height="32" Width="60"
                            FontSize="12"
                            Background="Transparent"
                            Foreground="#8B6F6F"
                            BorderBrush="#8B6F6F"
                            BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== КОНТЕНТ ===== -->
        <Grid Grid.Row="1">

            <!-- Индикатор загрузки -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Загрузка..." FontSize="18" Foreground="#7A7A7A"/>
            </StackPanel>

            <!-- Сообщение об ошибке -->
            <TextBlock Text="{Binding ErrorMessage}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="Red" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Нет результатов -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Объекты не найдены"
                           FontSize="18" Foreground="#7A7A7A"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <TextBlock Text="Попробуйте изменить строку поиска"
                           FontSize="13" Foreground="#AAAAAA"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Список карточек -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                <ItemsControl ItemsSource="{Binding Properties}" Margin="12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:PropertyCardControl/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
