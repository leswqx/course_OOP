<UserControl x:Class="MSM.Views.PropertyListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MSM.Controls"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="600" d:DesignWidth="960">

    <Grid Margin="0,70,0,0">
        <!-- ===== КОНТЕНТ: тулбар + панель фильтров + каталог ===== -->
        <!-- Тулбар с кнопкой фильтров -->
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <Button Content="{DynamicResource Filter.Title}"
                        Command="{Binding ToggleFilterCommand}"
                        Height="30" Padding="12,0" FontSize="13"
                        Background="{DynamicResource ButtonSecondaryBg}"
                        Foreground="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"/>
                <TextBlock VerticalAlignment="Center" FontSize="13" Margin="16,0,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="{DynamicResource Catalog.Found}"/><Run Text="{Binding ResultCount, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Боковая панель фильтров: Auto → схлопывается при Collapsed -->
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== ПАНЕЛЬ ФИЛЬТРОВ ===== -->
            <Border Grid.Column="0" Width="280"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsFilterVisible, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,12">

                        <TextBlock Text="{DynamicResource Filter.Title}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,14"/>

                        <!-- Сортировка -->
                        <TextBlock Text="{DynamicResource Filter.Sort}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <ComboBox SelectedValue="{Binding FilterSortBy}"
                                  SelectedValuePath="Tag"
                                  Height="32" Margin="0,0,0,12"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBoxItem Content="{DynamicResource Filter.Sort.DateDesc}" Tag="date_desc"/>
                            <ComboBoxItem Content="{DynamicResource Filter.Sort.PriceAsc}"  Tag="price_asc"/>
                            <ComboBoxItem Content="{DynamicResource Filter.Sort.PriceDesc}" Tag="price_desc"/>
                            <ComboBoxItem Content="{DynamicResource Filter.Sort.AreaAsc}"   Tag="area_asc"/>
                            <ComboBoxItem Content="{DynamicResource Filter.Sort.AreaDesc}"  Tag="area_desc"/>
                        </ComboBox>

                        <!-- Цена -->
                        <TextBlock Text="{DynamicResource Filter.Price}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FilterMinPrice, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="6,0"
                                     ToolTip="{DynamicResource Filter.From}"
                                     PreviewTextInput="NumericBox_PreviewTextInput"
                                     DataObject.Pasting="NumericBox_Pasting"/>
                            <TextBlock Grid.Column="1" Text="–"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding FilterMaxPrice, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="6,0"
                                     ToolTip="{DynamicResource Filter.To}"
                                     PreviewTextInput="NumericBox_PreviewTextInput"
                                     DataObject.Pasting="NumericBox_Pasting"/>
                        </Grid>

                        <!-- Площадь -->
                        <TextBlock Text="{DynamicResource Filter.Area}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FilterMinArea, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="6,0"
                                     ToolTip="{DynamicResource Filter.From}"
                                     PreviewTextInput="NumericBox_PreviewTextInput"
                                     DataObject.Pasting="NumericBox_Pasting"/>
                            <TextBlock Grid.Column="1" Text="–"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding FilterMaxArea, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="6,0"
                                     ToolTip="{DynamicResource Filter.To}"
                                     PreviewTextInput="NumericBox_PreviewTextInput"
                                     DataObject.Pasting="NumericBox_Pasting"/>
                        </Grid>

                        <!-- Комнат (от/до) -->
                        <TextBlock Text="{DynamicResource Filter.Rooms}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FilterMinRooms, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="6,0"
                                     ToolTip="{DynamicResource Filter.From}"
                                     PreviewTextInput="IntBox_PreviewTextInput"/>
                            <TextBlock Grid.Column="1" Text="–"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding FilterMaxRooms, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="6,0"
                                     ToolTip="{DynamicResource Filter.To}"
                                     PreviewTextInput="IntBox_PreviewTextInput"/>
                        </Grid>

                        <!-- Санузлы -->
                        <TextBlock Text="{DynamicResource Filter.Bathrooms}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FilterMinBathrooms, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="6,0"
                                     ToolTip="{DynamicResource Filter.From}"
                                     PreviewTextInput="IntBox_PreviewTextInput"/>
                            <TextBlock Grid.Column="1" Text="–"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding FilterMaxBathrooms, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Padding="6,0"
                                     ToolTip="{DynamicResource Filter.To}"
                                     PreviewTextInput="IntBox_PreviewTextInput"/>
                        </Grid>

                        <!-- Город -->
                        <TextBlock Text="{DynamicResource Filter.City}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <ComboBox SelectedItem="{Binding FilterCity, Mode=TwoWay}"
                                  ItemsSource="{Binding Cities}"
                                  Height="32" Margin="0,0,0,10"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="">
                                                        <Setter Property="Text" Value="{DynamicResource Filter.AllCities}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Район -->
                        <TextBlock Text="{DynamicResource Filter.District}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <ComboBox SelectedItem="{Binding FilterDistrict, Mode=TwoWay}"
                                  ItemsSource="{Binding Districts}"
                                  Height="32" Margin="0,0,0,10"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="">
                                                        <Setter Property="Text" Value="{DynamicResource Filter.AllDistricts}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Тип объекта -->
                        <TextBlock Text="{DynamicResource Filter.Type}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <ComboBox SelectedValue="{Binding FilterType}"
                                  SelectedValuePath="Tag"
                                  Height="32" Margin="0,0,0,12"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBoxItem Content="{DynamicResource Filter.AllTypes}" Tag=""/>
                            <ComboBoxItem Content="{DynamicResource Type.Apartment}"  Tag="apartment"/>
                            <ComboBoxItem Content="{DynamicResource Type.House}"      Tag="house"/>
                            <ComboBoxItem Content="{DynamicResource Type.Complex}"    Tag="complex"/>
                        </ComboBox>

                        <!-- Ипотека -->
                        <CheckBox Content="{DynamicResource Filter.Mortgage}"
                                  IsChecked="{Binding FilterMortgage}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Margin="0,0,0,8"/>

                        <!-- Ремонт -->
                        <CheckBox Content="{DynamicResource Filter.Renovation}"
                                  IsChecked="{Binding FilterRenovation}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Margin="0,0,0,16"/>

                        <!-- Кнопки Применить / Сбросить -->
                        <Button Content="{DynamicResource Filter.Apply}"
                                Command="{Binding LoadPropertiesCommand}"
                                Height="36" FontSize="13"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="White" BorderThickness="0"
                                Margin="0,0,0,8"/>

                        <Button Content="{DynamicResource Filter.Reset}"
                                Command="{Binding ResetFiltersCommand}"
                                Height="36" FontSize="13"
                                Background="Transparent"
                                Foreground="{DynamicResource AccentBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== ОСНОВНОЙ КОНТЕНТ ===== -->
            <Grid Grid.Column="1">

                <!-- Индикатор загрузки -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{DynamicResource Common.Loading}"
                               FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Сообщение об ошибке -->
                <TextBlock Text="{Binding ErrorMessage}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Нет результатов -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibility}}">
                    <Path Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center"
                          Fill="{DynamicResource TextSecondaryBrush}"
                          Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                    <TextBlock Text="{DynamicResource Catalog.NoResults}"
                               FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="{DynamicResource Catalog.NoResultsHint}"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Список карточек + кнопка "Показать ещё" -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding DisplayedProperties}" Margin="12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:PropertyCardControl>
                                        <controls:PropertyCardControl.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </controls:PropertyCardControl.InputBindings>
                                    </controls:PropertyCardControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Command="{Binding ShowMoreCommand}"
                                Visibility="{Binding CanShowMore, Converter={StaticResource BoolToVisibility}}"
                                HorizontalAlignment="Center" Margin="0,4,0,20"
                                Height="40" Padding="24,0" FontSize="13"
                                Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Button.Content>
                                <TextBlock>
                                    <Run Text="{DynamicResource Catalog.ShowMorePrefix}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding ShowMoreCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text=" "/>
                                    <Run Text="{DynamicResource Catalog.ShowMoreSuffix}"/>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
