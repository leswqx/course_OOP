<UserControl x:Class="MSM.Views.RealtorDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MSM.Controls"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="600" d:DesignWidth="960">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>
            <Grid Margin="16,0">
                <Button Content="{DynamicResource Common.Back}" Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left" Background="Transparent"
                        Foreground="{DynamicResource AccentBrush}" BorderThickness="0" FontSize="14"/>
                <TextBlock Text="{DynamicResource Realtor.Title}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="16,0">
                <RadioButton Content="{DynamicResource Realtor.MyProperties}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource BoolToVisibility}, ConverterParameter=0}"
                             GroupName="Tab" Style="{StaticResource TabRadioStyle}"/>
                <RadioButton Content="{DynamicResource Realtor.Appointments}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource BoolToVisibility}, ConverterParameter=1}"
                             GroupName="Tab" Style="{StaticResource TabRadioStyle}" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <Grid Grid.Row="2">

            <!-- ===== ВКЛАДКА: МОИ ОБЪЕКТЫ ===== -->
            <Grid Visibility="{Binding SelectedTab, Converter={StaticResource BoolToVisibility}, ConverterParameter=0}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Кнопка добавить + форма -->
                <StackPanel Grid.Row="0" Margin="16,12,16,0">
                    <Button Content="{DynamicResource Realtor.AddProperty}"
                            Command="{Binding ToggleFormCommand}"
                            HorizontalAlignment="Left"
                            Height="36" Padding="16,0" FontSize="13"
                            Background="{DynamicResource PrimaryBrush}"
                            Foreground="White" BorderThickness="0"/>

                    <!-- Форма добавления объекта -->
                    <Border Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="16" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Строка 0: Название + Тип -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource PropForm.Title}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormTitle, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource PropForm.Type}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <ComboBox SelectedValue="{Binding FormType}" SelectedValuePath="Tag" Height="32">
                                    <ComboBoxItem Content="{DynamicResource Type.Apartment}" Tag="apartment"/>
                                    <ComboBoxItem Content="{DynamicResource Type.House}"     Tag="house"/>
                                    <ComboBoxItem Content="{DynamicResource Type.Complex}"   Tag="complex"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Строка 1: Цена + Площадь + Комнат -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource PropForm.Price}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormPrice, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Width="120" Margin="0,0,8,0">
                                        <TextBlock Text="{DynamicResource PropForm.Area}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding FormArea, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0"/>
                                    </StackPanel>
                                    <StackPanel Width="80">
                                        <TextBlock Text="{DynamicResource PropForm.Rooms}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding FormRooms, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Строка 2: Этаж + Год -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Width="120" Margin="0,0,8,0">
                                        <TextBlock Text="{DynamicResource PropForm.Floor}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding FormFloor, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0"/>
                                    </StackPanel>
                                    <StackPanel Width="120">
                                        <TextBlock Text="{DynamicResource PropForm.TotalFloors}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding FormTotalFloors, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource PropForm.YearBuilt}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormYearBuilt, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0"/>
                            </StackPanel>

                            <!-- Строка 3: Город + Адрес -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource PropForm.City}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormCity, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource PropForm.Address}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormAddress, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0"/>
                            </StackPanel>

                            <!-- Строка 4: Описание -->
                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource PropForm.Description}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Height="70" Padding="8,6" TextWrapping="Wrap"
                                         AcceptsReturn="True" VerticalContentAlignment="Top"/>
                            </StackPanel>

                            <!-- Строка 5: Чекбоксы + кнопки -->
                            <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource PropForm.HasRepair}"
                                          IsChecked="{Binding FormHasRepair}"
                                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,16,0"/>
                                <CheckBox Content="{DynamicResource PropForm.Mortgage}"
                                          IsChecked="{Binding FormMortgage}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding FormError}" Foreground="{DynamicResource ErrorBrush}"
                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"
                                           Visibility="{Binding FormError, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="{DynamicResource PropForm.Cancel}"
                                        Command="{Binding ToggleFormCommand}"
                                        Height="34" Padding="16,0" FontSize="13" Margin="0,0,8,0"
                                        Background="Transparent"
                                        Foreground="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <Button Content="{DynamicResource PropForm.Save}"
                                        Command="{Binding SavePropertyCommand}"
                                        Height="34" Padding="16,0" FontSize="13"
                                        Background="{DynamicResource PrimaryBrush}"
                                        Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Список моих объектов -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding MyProperties}" Margin="12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:PropertyCardControl>
                                    <controls:PropertyCardControl.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </controls:PropertyCardControl.InputBindings>
                                </controls:PropertyCardControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ===== ВКЛАДКА: ЗАПИСИ КЛИЕНТОВ ===== -->
            <ScrollViewer Margin="16"
                          Visibility="{Binding SelectedTab, Converter={StaticResource BoolToVisibility}, ConverterParameter=1}">
                <ItemsControl ItemsSource="{Binding Appointments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                    Padding="16,10" Margin="0,0,0,8">
                                <Border.Effect>
                                    <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ClientName}" FontWeight="SemiBold"
                                                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding PropertyTitle}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding DateTime}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="12"
                                               Foreground="{Binding StatusColor}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>

                                    <!-- Кнопки только для новых записей -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="{DynamicResource Realtor.Confirm}"
                                                Command="{Binding DataContext.ConfirmAppointmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Id}"
                                                Height="30" Padding="10,0" FontSize="12" Margin="0,0,6,0"
                                                Background="{DynamicResource SuccessBrush}"
                                                Foreground="White" BorderThickness="0"/>
                                        <Button Content="{DynamicResource Realtor.Cancel}"
                                                Command="{Binding DataContext.CancelAppointmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Id}"
                                                Height="30" Padding="10,0" FontSize="12"
                                                Background="{DynamicResource ErrorBrush}"
                                                Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
