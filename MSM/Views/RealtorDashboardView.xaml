<UserControl x:Class="MSM.Views.RealtorDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MSM.Controls"
             xmlns:helpers="clr-namespace:MSM.Helpers"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="600" d:DesignWidth="960">
    <Grid Margin="0,70,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Вкладки (кнопки) -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                IsEnabled="{Binding IsCalendarClosed}">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <Button Content="{DynamicResource Nav.MyProfile}"
                        Command="{Binding SetTab3Command}" Padding="12,0" FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab3}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Realtor.MyProperties}"
                        Command="{Binding SetTab0Command}" Padding="12,0" FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab0}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding SetTab1Command}" Padding="12,0" FontSize="13" Cursor="Hand">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Realtor.Appointments}" VerticalAlignment="Center"/>
                            <Border Background="#EF5350" CornerRadius="8" Margin="6,0,0,0" Padding="5,1"
                                    Visibility="{Binding NewAppointmentsCount, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding NewAppointmentsCount}" FontSize="10" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Button.Content>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab1}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Admin.Stats}"
                        Command="{Binding SetTab2Command}" Padding="12,0" FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="0,0,0,3"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTab2}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- Кнопка открытия календаря -->
                <Button Content="{DynamicResource Realtor.Schedule}"
                        Command="{Binding OpenCalendarCommand}"
                        Padding="12,0" FontSize="13" Cursor="Hand" Margin="16,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Padding="12,0" BorderThickness="1" CornerRadius="6"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <Grid Grid.Row="1">

            <!-- ===== ВКЛАДКА 0: МОИ ОБЪЕКТЫ ===== -->
            <Grid Visibility="{Binding ShowTab0, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="16,12,16,0">

                    <!-- Баннер успеха -->
                    <Border Background="#E8F5E9" CornerRadius="8" Margin="0,0,0,10" Padding="12,8"
                            Visibility="{Binding FormSuccess, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"
                                  Fill="#388E3C"
                                  Data="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
                            <TextBlock Text="{DynamicResource Realtor.PropertyAdded}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#2E7D32" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Верхняя строка: кнопка добавить + фильтры -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="{DynamicResource Realtor.AddProperty}"
                                Command="{Binding ToggleFormCommand}"
                                Height="36" Padding="16,0" FontSize="13"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="White" BorderThickness="0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{DynamicResource Realtor.FilterAll}" Command="{Binding SetPropFilterAllCommand}"
                                    Height="30" Padding="14,0" FontSize="12" Margin="0,0,4,0"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPropFilterAll}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{DynamicResource Realtor.FilterActive}" Command="{Binding SetPropFilterActiveCommand}"
                                    Height="30" Padding="14,0" FontSize="12" Margin="0,0,4,0"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPropFilterActive}" Value="True">
                                                <Setter Property="Background" Value="#42A5F5"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{DynamicResource Realtor.FilterHidden}" Command="{Binding SetPropFilterHiddenCommand}"
                                    Height="30" Padding="14,0" FontSize="12" Margin="0,0,4,0"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPropFilterHidden}" Value="True">
                                                <Setter Property="Background" Value="#9E9E9E"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{DynamicResource Realtor.FilterSold}" Command="{Binding SetPropFilterSoldCommand}"
                                    Height="30" Padding="14,0" FontSize="12"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPropFilterSold}" Value="True">
                                                <Setter Property="Background" Value="#FF8F00"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Поиск по названию/городу -->
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="10,0" Margin="0,8,0,0" Height="36">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="14" Height="14" Stretch="Uniform"
                                  Margin="0,0,8,0" VerticalAlignment="Center"
                                  Fill="{DynamicResource TextSecondaryBrush}"
                                  Data="M15.5,14h-.79l-.28-.27A6.471,6.471,0,0,0,16,9.5,6.5,6.5,0,1,0,9.5,16c1.61,0,3.09-.59,4.23-1.57l.27.28v.79l5,4.99L20.49,19Zm-6,0C7.01,14,5,11.99,5,9.5S7.01,5,9.5,5,14,7.01,14,9.5,11.99,14,9.5,14Z"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding MyPropertiesSearch, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalAlignment="Center" FontSize="13"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <!-- Подсказка (плейсхолдер) -->
                            <TextBlock Grid.Column="1" IsHitTestVisible="False"
                                       Text="{DynamicResource Realtor.SearchPlaceholder}"
                                       FontSize="13" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MyPropertiesSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Кнопка очистки — показывается только когда есть текст -->
                            <Button Grid.Column="2" Content="✕"
                                    Command="{Binding ClearMySearchCommand}"
                                    Width="20" Height="20" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    FontSize="11" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MyPropertiesSearch}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Сортировка -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource Realtor.SortLabel}" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource Realtor.SortNew}" Command="{Binding SortByDateCommand}"
                                Height="26" Padding="10,0" FontSize="11" Margin="0,0,4,0" BorderThickness="1">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMyPropSortDate}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource Realtor.SortPriceAsc}" Command="{Binding SortByPriceAscCommand}"
                                Height="26" Padding="10,0" FontSize="11" Margin="0,0,4,0" BorderThickness="1">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMyPropSortPriceAsc}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource Realtor.SortPriceDesc}" Command="{Binding SortByPriceDescCommand}"
                                Height="26" Padding="10,0" FontSize="11" Margin="0,0,4,0" BorderThickness="1">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMyPropSortPriceDesc}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource Realtor.SortAZ}" Command="{Binding SortByTitleCommand}"
                                Height="26" Padding="10,0" FontSize="11" BorderThickness="1">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMyPropSortTitle}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredMyProperties}" Margin="12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Цельная карточка с кнопками внутри -->
                                <Border Width="280" Margin="8"
                                        Background="{DynamicResource CardBrush}"
                                        CornerRadius="12" ClipToBounds="True" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>

                                    <Grid ClipToBounds="True">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="180"/>
                                            <RowDefinition Height="130"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Фото -->
                                        <Grid Grid.Row="0" ClipToBounds="True">
                                            <Border Background="{DynamicResource PlaceholderBrush}"
                                                    Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                                                <Path Width="48" Height="48" Stretch="Uniform"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Fill="{DynamicResource TextSecondaryBrush}"
                                                      Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/>
                                            </Border>
                                            <Image Source="{Binding MainImage}" Stretch="UniformToFill"
                                                   Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"/>

                                            <!-- Бейдж типа -->
                                            <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="4"
                                                    HorizontalAlignment="Left" VerticalAlignment="Top"
                                                    Margin="10,10,0,0" Padding="8,3">
                                                <TextBlock Text="{Binding PropertyTypeDisplay}"
                                                           Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>

                                            <!-- Бейдж статуса (не active) -->
                                            <Border CornerRadius="4"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,10,10,0" Padding="8,3"
                                                    Visibility="{Binding IsSoldable, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="sold">
                                                                <Setter Property="Background" Value="#7CB342"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="hidden">
                                                                <Setter Property="Background" Value="#9E9E9E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                        <Setter Property="Background" Value="#9E9E9E"/>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{DynamicResource Status.Hidden}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="sold">
                                                                    <Setter Property="Text" Value="{DynamicResource Status.Sold}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>

                                        <!-- Информация -->
                                        <StackPanel Grid.Row="1" Margin="14,12,14,12">
                                            <TextBlock Text="{Binding Price, Converter={StaticResource PriceToString}}"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,10"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Path Width="11" Height="11" Stretch="Uniform" Margin="0,0,5,0"
                                                      VerticalAlignment="Center"
                                                      Fill="{DynamicResource PrimaryBrush}"
                                                      Data="M12,2C8.13,2 5,5.13 5,9c0,5.25 7,13 7,13s7-7.75 7-13C19,5.13 15.87,2 12,2z M12,11.5c-1.38,0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5,1.12 2.5,2.5S13.38,11.5 12,11.5z"/>
                                                <TextBlock Text="{Binding City}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <WrapPanel Margin="0,2,0,0">
                                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                                        Padding="8,4" Margin="0,0,6,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"
                                                              VerticalAlignment="Center"
                                                              Fill="{DynamicResource TextSecondaryBrush}"
                                                              Data="M7,13C8.66,13 10,11.66 10,10C10,8.34 8.66,7 7,7C5.34,7 4,8.34 4,10C4,11.66 5.34,13 7,13ZM19,7H11V14H3V7H1V20H3V17H21V20H23V11C23,8.79 21.21,7 19,7Z"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Text="{Binding Rooms, StringFormat='{}{0} комн.'}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                                        Padding="8,4" Margin="0,0,6,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Width="11" Height="11" Stretch="Uniform" Margin="0,0,4,0"
                                                              VerticalAlignment="Center"
                                                              Fill="{DynamicResource TextSecondaryBrush}"
                                                              Data="M21,3H3C1.9,3 1,3.9 1,5V19C1,20.1 1.9,21 3,21H21C22.1,21 23,20.1 23,19V5C23,3.9 22.1,3 21,3ZM21,19H3V5H21V19Z"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Text="{Binding Area, StringFormat='{}{0:F0} м²'}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                                        Padding="8,4"
                                                        Visibility="{Binding Bathrooms, Converter={StaticResource BoolToVisibility}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Width="11" Height="11" Stretch="Uniform" Margin="0,0,4,0"
                                                              VerticalAlignment="Center"
                                                              Fill="{DynamicResource TextSecondaryBrush}"
                                                              Data="M9,2A1,1 0 0,0 8,3V5H5C3.9,5 3,5.9 3,7V20A1,1 0 0,0 4,21H20A1,1 0 0,0 21,20V7C21,5.9 20.1,5 19,5H16V3A1,1 0 0,0 15,2H9M9,4H15V5H9V4M5,7H19V19H5V7M9,9V11H7V13H9V15H11V13H13V11H11V9H9M13,9V11H15V13H13V15H15V17H17V15H15V13H17V11H15V9H13Z"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Text="{Binding Bathrooms}"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>

                                        <!-- Кнопки управления — внутри карточки -->
                                        <Border Grid.Row="2"
                                                BorderBrush="{DynamicResource SeparatorBrush}"
                                                BorderThickness="0,1,0,0"
                                                Padding="8,7">
                                            <StackPanel>
                                                <!-- Верхняя строка: Скрыть + Продано — скрывается целиком когда sold -->
                                                <Grid Margin="0,0,0,4"
                                                      Visibility="{Binding IsToggleHideVisible, Converter={StaticResource BoolToVisibility}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Content="{Binding ToggleHideLabel}"
                                                            Command="{Binding DataContext.ToggleHiddenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Height="26" FontSize="11" Margin="0,0,3,0"
                                                            Background="Transparent"
                                                            Foreground="#9E9E9E"
                                                            BorderBrush="#9E9E9E" BorderThickness="1"/>
                                                    <Button Grid.Column="1"
                                                            Content="{DynamicResource Realtor.SetSold}"
                                                            Command="{Binding DataContext.SetSoldCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding IsSoldable, Converter={StaticResource BoolToVisibility}}"
                                                            Height="26" FontSize="11"
                                                            Background="Transparent" Foreground="#7CB342"
                                                            BorderBrush="#7CB342" BorderThickness="1"/>
                                                </Grid>
                                                <!-- Кнопка "Вернуть в продажу" — только для sold -->
                                                <Button Content="{DynamicResource Realtor.RestoreActive}"
                                                        Command="{Binding DataContext.SetActiveFromSoldCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding IsRestorable, Converter={StaticResource BoolToVisibility}}"
                                                        Height="26" FontSize="11" Margin="0,0,0,4"
                                                        Background="Transparent" Foreground="#42A5F5"
                                                        BorderBrush="#42A5F5" BorderThickness="1"/>
                                                <!-- Нижняя строка: Изменить + Удалить — всегда видна -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Content="{DynamicResource Realtor.Edit}"
                                                            Command="{Binding DataContext.OpenEditFormCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Height="26" FontSize="11" Margin="0,0,3,0"
                                                            Background="Transparent"
                                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                                    <Button Grid.Column="1"
                                                            Content="{DynamicResource Realtor.Delete}"
                                                            Command="{Binding DataContext.DeletePropertyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Height="26" FontSize="11"
                                                            Background="Transparent" Foreground="#EF5350"
                                                            BorderBrush="#EF5350" BorderThickness="1"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ===== ВКЛАДКА 1: ЗАПИСИ КЛИЕНТОВ ===== -->
            <Grid Visibility="{Binding ShowTab1, Converter={StaticResource BoolToVisibility}}" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Фильтры записей -->
                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Realtor.ApptFilterLabel}" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>

                        <!-- Фильтр по объекту -->
                        <TextBlock Text="{DynamicResource Realtor.ApptPropLabel}" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                        <ComboBox SelectedItem="{Binding ApptFilterProperty, Mode=TwoWay}"
                                  ItemsSource="{Binding AppointmentPropertyTitles}"
                                  Width="220" Height="30"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  Margin="0,0,14,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="">
                                                        <Setter Property="Text" Value="{DynamicResource Realtor.AllProperties}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Фильтр по статусу -->
                        <TextBlock Text="{DynamicResource Realtor.ApptStatusLabel}" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                        <ComboBox SelectedValue="{Binding ApptFilterStatus}"
                                  SelectedValuePath="Tag"
                                  Width="150" Height="30"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  Margin="0,0,10,0">
                            <ComboBoxItem Content="{DynamicResource Realtor.AllStatuses}" Tag=""/>
                            <ComboBoxItem Content="{DynamicResource Realtor.StatusNew}"       Tag="new"/>
                            <ComboBoxItem Content="{DynamicResource Realtor.StatusConfirmed}" Tag="confirmed"/>
                            <ComboBoxItem Content="{DynamicResource Realtor.StatusCompleted}" Tag="completed"/>
                            <ComboBoxItem Content="{DynamicResource Realtor.StatusCancelled}" Tag="cancelled"/>
                        </ComboBox>

                        <!-- Фильтр по дате -->
                        <TextBlock Text="{DynamicResource Realtor.DateLabel}" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="14,0,6,0"/>
                        <Button Content="{DynamicResource Realtor.DateAll}" Command="{Binding SetApptDateAllCommand}"
                                Height="30" Padding="10,0" FontSize="12" Margin="0,0,4,0"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsApptDateAll}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource Realtor.DateToday}" Command="{Binding SetApptDateTodayCommand}"
                                Height="30" Padding="10,0" FontSize="12" Margin="0,0,4,0"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsApptDateToday}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource Realtor.DateWeek}" Command="{Binding SetApptDateWeekCommand}"
                                Height="30" Padding="10,0" FontSize="12" Margin="0,0,4,0"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsApptDateWeek}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource Realtor.DateMonth}" Command="{Binding SetApptDateMonthCommand}"
                                Height="30" Padding="10,0" FontSize="12" Margin="0,0,14,0"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsApptDateMonth}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="{DynamicResource Realtor.DateReset}" Command="{Binding ResetApptFilterCommand}"
                                Height="30" Padding="10,0" FontSize="12"
                                Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding NoAppointments, Converter={StaticResource BoolToVisibility}}">
                    <Path Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center"
                          Fill="{DynamicResource TextSecondaryBrush}"
                          Data="M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V6A2,2 0 0,0 19,4M19,20H5V10H19V20M19,8H5V6H19V8Z"/>
                    <TextBlock Text="{DynamicResource Realtor.NoAppt}" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Appointments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                        Padding="16,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ClientName}" FontWeight="SemiBold"
                                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding PropertyTitle}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding DateTime}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding HasClientPhone, Converter={StaticResource BoolToVisibility}}">
                                                <Path Width="11" Height="11" Stretch="Uniform" Margin="0,0,4,0" VerticalAlignment="Center"
                                                      Fill="{DynamicResource TextSecondaryBrush}"
                                                      Data="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z"/>
                                                <TextBlock Text="{Binding ClientPhone}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ClientEmail}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Visibility="{Binding ClientEmail, Converter={StaticResource BoolToVisibility}}"/>
                                            <Border Background="{DynamicResource CardBrush}"
                                                    CornerRadius="4" Padding="6,4" Margin="0,4,0,0"
                                                    Visibility="{Binding HasComment, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding Comment}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" FontStyle="Italic"/>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Status}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Для "new": Подтвердить -->
                                            <Button Content="{DynamicResource Realtor.Confirm}"
                                                    Command="{Binding DataContext.ConfirmAppointmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVisibility}}"
                                                    Height="30" Padding="10,0" FontSize="12" Margin="0,0,4,0"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    Foreground="White" BorderThickness="0"/>
                                            <!-- Для "confirmed": Завершить -->
                                            <Button Content="{DynamicResource Realtor.Complete}"
                                                    Command="{Binding DataContext.CompleteAppointmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Visibility="{Binding CanComplete, Converter={StaticResource BoolToVisibility}}"
                                                    Height="30" Padding="10,0" FontSize="12" Margin="0,0,4,0"
                                                    Background="#7CB342"
                                                    Foreground="White" BorderThickness="0"/>
                                            <!-- Для "new" и "confirmed": Отменить -->
                                            <Button Content="{DynamicResource Realtor.Cancel}"
                                                    Command="{Binding DataContext.CancelAppointmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibility}}"
                                                    Height="30" Padding="10,0" FontSize="12"
                                                    Background="{DynamicResource ErrorBrush}"
                                                    Foreground="White" BorderThickness="0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ===== МОДАЛЬНАЯ ФОРМА ДОБАВЛЕНИЯ ОБЪЕКТА ===== -->
            <Grid Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibility}}"
                  Background="#88000000" Panel.ZIndex="10">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="24" MaxWidth="640"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxHeight="590">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.35"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Realtor.AddProperty}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Content="✕" Command="{Binding ToggleFormCommand}"
                                    HorizontalAlignment="Right" Width="30" Height="30"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    FontSize="16" Cursor="Hand"/>
                        </Grid>

                        <!-- Поля формы -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,0,14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Название * + Тип -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{DynamicResource PropForm.Title}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text=" *" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding FormTitle, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TitleInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.Type}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox SelectedValue="{Binding FormType}" SelectedValuePath="Tag" Height="32">
                                        <ComboBoxItem Content="{DynamicResource Type.Apartment}" Tag="apartment" IsSelected="True"/>
                                        <ComboBoxItem Content="{DynamicResource Type.House}"     Tag="house"/>
                                        <ComboBoxItem Content="{DynamicResource Type.Complex}"   Tag="complex"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Цена * + Площадь * + Комнаты * -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{DynamicResource PropForm.Price}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text=" *" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding FormPrice, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PriceInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{DynamicResource PropForm.Area}" FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text=" *" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                                            </StackPanel>
                                            <TextBox Text="{Binding FormArea, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AreaInvalid}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{DynamicResource PropForm.Rooms}" FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text=" *" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                                            </StackPanel>
                                            <TextBox Text="{Binding FormRooms, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RoomsInvalid}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="{DynamicResource PropForm.Bathrooms}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding FormBathrooms, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- Этаж + Год -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Width="120" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource PropForm.Floor}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding FormFloor, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                        </StackPanel>
                                        <StackPanel Width="120">
                                            <TextBlock Text="{DynamicResource PropForm.TotalFloors}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding FormTotalFloors, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.YearBuilt}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding FormYearBuilt, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                </StackPanel>

                                <!-- Город * + Адрес * -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{DynamicResource PropForm.City}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text=" *" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding FormCity, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CityInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{DynamicResource PropForm.Address}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text=" *" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding FormAddress, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AddressInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>

                                <!-- Район -->
                                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.District}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding FormDistrict, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                </StackPanel>

                                <!-- Описание * -->
                                <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{DynamicResource PropForm.Description}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text=" *" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                             Height="70" Padding="8,6" TextWrapping="Wrap"
                                             AcceptsReturn="True" VerticalContentAlignment="Top">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DescriptionInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>

                                <!-- Картинки -->
                                <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="{DynamicResource PropForm.Images}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Content="{DynamicResource PropForm.AddImage}"
                                                Command="{Binding AddImageCommand}"
                                                Height="28" Padding="12,0" FontSize="11"
                                                Background="{DynamicResource SurfaceBrush}"
                                                Foreground="{DynamicResource AccentBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding FormImages}"
                                                  Visibility="{Binding FormImages.Count, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,4" CornerRadius="4"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                    <Grid>
                                                        <Image Source="{Binding Data, Converter={StaticResource ByteArrayToImage}}"
                                                               Width="80" Height="60" Stretch="UniformToFill"/>
                                                        <Button Content="✕" Width="20" Height="20"
                                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                Margin="0,2,2,0" FontSize="10" Padding="0"
                                                                Command="{Binding DataContext.RemoveImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="{DynamicResource ErrorBrush}"
                                                                Foreground="White" BorderThickness="0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- Нижняя панель: чекбоксы + ошибка + кнопки -->
                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Content="{DynamicResource PropForm.HasRepair}"
                                          IsChecked="{Binding FormHasRepair}"
                                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,16,0"/>
                                <CheckBox Content="{DynamicResource PropForm.Mortgage}"
                                          IsChecked="{Binding FormMortgage}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding FormError}" Foreground="{DynamicResource ErrorBrush}"
                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0" MaxWidth="200"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding FormError, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="{DynamicResource PropForm.Cancel}"
                                        Command="{Binding ToggleFormCommand}"
                                        Height="36" Padding="18,0" Margin="0,0,8,0"
                                        Background="{DynamicResource SurfaceBrush}"
                                        Foreground="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <Button Content="{DynamicResource PropForm.Save}"
                                        Command="{Binding SavePropertyCommand}"
                                        Height="36" Padding="18,0"
                                        Background="{DynamicResource PrimaryBrush}"
                                        Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== МОДАЛЬНАЯ ФОРМА РЕДАКТИРОВАНИЯ ОБЪЕКТА ===== -->
            <Grid Visibility="{Binding IsEditFormVisible, Converter={StaticResource BoolToVisibility}}"
                  Background="#88000000" Panel.ZIndex="10">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="24" MaxWidth="640"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxHeight="580">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.35"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <TextBlock Grid.Row="0" Text="{DynamicResource Realtor.EditProperty}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>

                        <!-- Поля формы -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,0,14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Название + Тип -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.Title}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EditTitleInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.Type}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox SelectedValue="{Binding EditType}" SelectedValuePath="Tag" Height="32">
                                        <ComboBoxItem Content="{DynamicResource Type.Apartment}" Tag="apartment"/>
                                        <ComboBoxItem Content="{DynamicResource Type.House}"     Tag="house"/>
                                        <ComboBoxItem Content="{DynamicResource Type.Complex}"   Tag="complex"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Цена + Площадь/Комнаты -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.Price}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditPrice, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EditPriceInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{DynamicResource PropForm.Area}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding EditArea, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EditAreaInvalid}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{DynamicResource PropForm.Rooms}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding EditRooms, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EditRoomsInvalid}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="{DynamicResource PropForm.Bathrooms}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding EditBathrooms, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- Этаж + Год -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Width="110" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource PropForm.Floor}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding EditFloor, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                        </StackPanel>
                                        <StackPanel Width="110">
                                            <TextBlock Text="{DynamicResource PropForm.TotalFloors}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding EditTotalFloors, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.YearBuilt}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditYearBuilt, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                </StackPanel>

                                <!-- Город + Адрес -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.City}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditCity, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EditCityInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.Address}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EditAddressInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>

                                <!-- Район -->
                                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.District}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditDistrict, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="5,0"/>
                                </StackPanel>

                                <!-- Описание -->
                                <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource PropForm.Description}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                             Height="64" Padding="8,6" TextWrapping="Wrap"
                                             AcceptsReturn="True" VerticalContentAlignment="Top">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EditDescriptionInvalid}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>

                                <!-- Фото при редактировании -->
                                <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="{DynamicResource PropForm.Images}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Content="{DynamicResource PropForm.AddImage}"
                                                Command="{Binding AddEditImageCommand}"
                                                Height="28" Padding="12,0" FontSize="11"
                                                Background="{DynamicResource SurfaceBrush}"
                                                Foreground="{DynamicResource AccentBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding EditImages}"
                                                  Visibility="{Binding EditImages.Count, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,4" CornerRadius="4"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                    <Grid>
                                                        <Image Source="{Binding Data, Converter={StaticResource ByteArrayToImage}}"
                                                               Width="80" Height="60" Stretch="UniformToFill"/>
                                                        <Button Content="✕" Width="20" Height="20"
                                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                Margin="0,2,2,0" FontSize="10" Padding="0"
                                                                Command="{Binding DataContext.RemoveEditImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="{DynamicResource ErrorBrush}"
                                                                Foreground="White" BorderThickness="0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Чекбоксы -->
                                <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3"
                                            Orientation="Horizontal" Margin="0,0,0,4">
                                    <CheckBox Content="{DynamicResource PropForm.HasRepair}"
                                              IsChecked="{Binding EditHasRepair}"
                                              Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,16,0"/>
                                    <CheckBox Content="{DynamicResource PropForm.Mortgage}"
                                              IsChecked="{Binding EditMortgage}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- Кнопки и ошибка -->
                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding EditError}"
                                       Foreground="{DynamicResource ErrorBrush}" FontSize="12"
                                       VerticalAlignment="Center" TextWrapping="Wrap"
                                       Visibility="{Binding EditError, Converter={StaticResource BoolToVisibility}}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="{DynamicResource PropForm.Cancel}"
                                        Command="{Binding CloseEditFormCommand}"
                                        Height="36" Padding="18,0" Margin="0,0,8,0"
                                        Background="{DynamicResource SurfaceBrush}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <Button Content="{DynamicResource PropForm.Save}"
                                        Command="{Binding SaveEditCommand}"
                                        Height="36" Padding="18,0"
                                        Background="{DynamicResource PrimaryBrush}"
                                        Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== ВКЛАДКА 2: СТАТИСТИКА ===== -->
            <ScrollViewer Visibility="{Binding ShowTab2, Converter={StaticResource BoolToVisibility}}" Margin="16">
                <StackPanel>

                    <!-- Фильтр периода -->
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="14,10" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Realtor.PeriodLabel}" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,0"/>
                            <Button Content="{DynamicResource Realtor.PeriodAll}" Command="{Binding SetStatPeriodAllCommand}"
                                    Height="30" Padding="14,0" FontSize="12" Margin="0,0,4,0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPeriodAll}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{DynamicResource Realtor.PeriodMonth}" Command="{Binding SetStatPeriodMonthCommand}"
                                    Height="30" Padding="14,0" FontSize="12" Margin="0,0,4,0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPeriodMonth}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{DynamicResource Realtor.PeriodQuarter}" Command="{Binding SetStatPeriodQuarterCommand}"
                                    Height="30" Padding="14,0" FontSize="12" Margin="0,0,4,0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPeriodQuarter}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{DynamicResource Realtor.PeriodYear}" Command="{Binding SetStatPeriodYearCommand}"
                                    Height="30" Padding="14,0" FontSize="12" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPeriodYear}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Счётчики: объекты (всегда за всё время) -->
                    <UniformGrid Columns="3" Margin="0,0,0,10">

                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,8,0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#1565C0"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Realtor.StatTotalProps}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding StatTotal}" FontSize="28" FontWeight="Bold" Foreground="#1565C0" Margin="0,4,0,0"/>
                                    <TextBlock Text="{DynamicResource Realtor.StatAllTime}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,8,0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#2E7D32"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Realtor.StatActiveProps}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding StatActive}" FontSize="28" FontWeight="Bold" Foreground="#2E7D32" Margin="0,4,0,0"/>
                                    <TextBlock Text="{DynamicResource Realtor.StatOnSale}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#FF8F00"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Realtor.StatSoldLabel}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding StatSold}" FontSize="28" FontWeight="Bold" Foreground="#FF8F00" Margin="0,4,0,0"/>
                                    <TextBlock Text="{DynamicResource Realtor.StatAllTime}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </UniformGrid>

                    <!-- Счётчики: записи (фильтруются периодом) + рейтинг -->
                    <UniformGrid Columns="3" Margin="0,0,0,16">

                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,8,0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#8E24AA"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Realtor.StatApptPeriod}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding StatTotalAppt}" FontSize="28" FontWeight="Bold" Foreground="#8E24AA" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,8,0" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#00897B"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Realtor.StatCompletedPeriod}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding StatCompletedAppt}" FontSize="28" FontWeight="Bold" Foreground="#00897B" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F4B942"/>
                                <StackPanel Grid.Row="1" Margin="16,10,16,14">
                                    <TextBlock Text="{DynamicResource Realtor.StatAvgRating}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding StatRating, StringFormat='{}{0:F1}'}"
                                                   FontSize="28" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" ★" FontSize="24" FontWeight="Bold"
                                                   Foreground="#F4B942" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{DynamicResource Realtor.StatByReviews}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </UniformGrid>

                    <!-- Балл эффективности -->
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                            Padding="20,16" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                        </Border.Effect>
                        <Border BorderBrush="{Binding StatScoreColor, Converter={StaticResource StringToBrush}}"
                                BorderThickness="2" CornerRadius="6" Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Realtor.StatMyScore}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding StatScore}" FontSize="42" FontWeight="Bold"
                                               Foreground="{Binding StatScoreColor, Converter={StaticResource StringToBrush}}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Realtor.StatOf100}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                                    <TextBlock Text="{Binding StatScoreLabel}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{Binding StatScoreColor, Converter={StaticResource StringToBrush}}"
                                               Margin="0,0,0,10"/>
                                    <Border Width="180" Height="10" CornerRadius="5"
                                            Background="{DynamicResource BorderBrush}"
                                            HorizontalAlignment="Left" Margin="0,0,0,12">
                                        <Border Height="10" HorizontalAlignment="Left" CornerRadius="5"
                                                Width="{Binding StatScoreBarWidth}"
                                                Background="{Binding StatScoreColor, Converter={StaticResource StringToBrush}}"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Realtor.StatFormula}"
                                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- График записей по месяцам -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Realtor.StatApptByMonth}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <lvc:CartesianChart Series="{Binding RatingSeriesData}"
                                                XAxes="{Binding RatingXAxes}" Height="240"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== ВКЛАДКА 3: МОЙ ПРОФИЛЬ ===== -->
            <ScrollViewer Visibility="{Binding ShowTab3, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto">
                <Grid Margin="24,24,24,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Аватар -->
                    <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="28,20">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="90" Height="90" CornerRadius="45" ClipToBounds="True"
                                    Background="{DynamicResource PlaceholderBrush}" Margin="0,0,0,10">
                                <Grid>
                                    <Path Width="40" Height="40" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Visibility="{Binding ProfileAvatar, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}"
                                          Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                    <Image Source="{Binding ProfileAvatar, Converter={StaticResource ByteArrayToImage}}" Stretch="UniformToFill"
                                           Visibility="{Binding ProfileAvatar, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding ProfileLogin}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Realtor.RoleLabel}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="{DynamicResource Profile.UploadPhoto}" Command="{Binding UploadProfileAvatarCommand}"
                                        Height="30" Padding="14,0" FontSize="12" Margin="0,0,8,0"
                                        Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                                <Button Content="{DynamicResource Profile.RemovePhoto}" Command="{Binding RemoveProfileAvatarCommand}"
                                        Height="30" Padding="14,0" FontSize="12"
                                        Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Visibility="{Binding ProfileAvatar, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Две колонки: личные данные | смена пароля -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Личные данные -->
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="28,24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="14" ShadowDepth="2" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Profile.PersonalData}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,22"/>
                                <TextBlock Text="{DynamicResource Profile.FullName}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfileFullName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="{DynamicResource Profile.Email}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfileEmail, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="{DynamicResource Profile.Phone}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfilePhone, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="{DynamicResource Realtor.ProfileAbout}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ProfileDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Height="80" Padding="12,10" TextWrapping="Wrap"
                                         AcceptsReturn="True" VerticalContentAlignment="Top" Margin="0,0,0,22"/>
                                <Button Content="{DynamicResource Profile.Save}" Command="{Binding SaveProfileCommand}"
                                        Height="44" FontSize="14" FontWeight="SemiBold"
                                        Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                                <TextBlock Margin="0,12,0,0" FontSize="13" TextWrapping="Wrap"
                                           Text="{Binding ProfileResult}"
                                           Visibility="{Binding ProfileResult, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProfileSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ProfileSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Смена пароля -->
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="28,24">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="14" ShadowDepth="2" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Profile.ChangePassword}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,22"/>
                                <TextBlock Text="{DynamicResource Profile.OldPassword}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding ProfileOldPassword, Mode=TwoWay}"
                                             Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="{DynamicResource Profile.NewPassword}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding ProfileNewPassword, Mode=TwoWay}"
                                             Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,18"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="{DynamicResource Profile.ConfirmPassword}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding ProfileConfirmPassword, Mode=TwoWay}"
                                             Height="42" FontSize="14" Padding="5,0" Margin="0,0,0,22"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                <Button Content="{DynamicResource Profile.ChangePasswordBtn}" Command="{Binding ChangeProfilePasswordCommand}"
                                        Height="44" FontSize="14" FontWeight="SemiBold"
                                        Background="Transparent"
                                        Foreground="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"/>
                                <TextBlock Margin="0,12,0,0" FontSize="13" TextWrapping="Wrap"
                                           Text="{Binding PasswordResult}"
                                           Visibility="{Binding PasswordResult, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PasswordSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PasswordSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <!-- ===== МОДАЛЬНЫЙ ПОПАП: КАЛЕНДАРЬ РАСПИСАНИЯ ===== -->
            <Grid Visibility="{Binding ShowCalendarOverlay, Converter={StaticResource BoolToVisibility}}"
                  Panel.ZIndex="100">
                <Border Background="#A0000000"/>
                <Border Background="{DynamicResource CardBrush}" CornerRadius="14"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="460" Padding="0" MaxHeight="620">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="28" ShadowDepth="0" Opacity="0.35"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Заголовок -->
                        <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="14,14,0,0" Padding="18,12">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="‹" Command="{Binding CalendarPrevCommand}"
                                            Width="28" Height="28" Cursor="Hand"
                                            Background="Transparent" Foreground="White"
                                            BorderThickness="1" BorderBrush="#60FFFFFF"
                                            FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CalendarMonthLabel}"
                                               FontSize="14" FontWeight="Bold" Foreground="White"
                                               VerticalAlignment="Center" Margin="12,0"/>
                                    <Button Content="›" Command="{Binding CalendarNextCommand}"
                                            Width="28" Height="28" Cursor="Hand"
                                            Background="Transparent" Foreground="White"
                                            BorderThickness="1" BorderBrush="#60FFFFFF"
                                            FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <Button Content="✕" Command="{Binding CloseCalendarCommand}"
                                        HorizontalAlignment="Right" Width="28" Height="28"
                                        Cursor="Hand" Background="Transparent" Foreground="White"
                                        BorderThickness="0" FontSize="14"/>
                            </Grid>
                        </Border>

                        <!-- Подсказка -->
                        <Border Background="{DynamicResource SurfaceBrush}" Margin="16,12,16,0" Padding="12,8" CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"
                                      Fill="{DynamicResource TextSecondaryBrush}"
                                      Data="M13,9H11V7H13M13,17H11V11H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"
                                           Text="{DynamicResource Realtor.CalendarHint}"/>
                            </StackPanel>
                        </Border>

                        <!-- Календарная сетка -->
                        <StackPanel Margin="16,12,16,0">
                            <UniformGrid Columns="7" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource Detail.Mon}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{DynamicResource Detail.Tue}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{DynamicResource Detail.Wed}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{DynamicResource Detail.Thu}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{DynamicResource Detail.Fri}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{DynamicResource Detail.Sat}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#EF5350"/>
                                <TextBlock Text="{DynamicResource Detail.Sun}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#EF5350"/>
                            </UniformGrid>
                            <ItemsControl ItemsSource="{Binding CalendarDays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectCalendarDayCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" Margin="2" Height="42" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="8">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Day}" FontSize="13" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Border Width="20" Height="4" CornerRadius="2"
                                                        Background="{Binding DotColor}" Margin="0,2,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AppointmentCount}" Value="0">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Легенда -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,12">
                                <Border Width="10" Height="4" CornerRadius="2" Background="#7CB342" Margin="0,0,4,0"/>
                                <TextBlock Text="1" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                                <Border Width="10" Height="4" CornerRadius="2" Background="#FF8F00" Margin="0,0,4,0"/>
                                <TextBlock Text="2–3" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                                <Border Width="10" Height="4" CornerRadius="2" Background="#EF5350" Margin="0,0,4,0"/>
                                <TextBlock Text="4+" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                                <Border Width="10" Height="4" CornerRadius="2" Background="#9E9E9E" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Realtor.CalendarBlocked}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Записи выбранного дня -->
                        <Border Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="0,0,14,14" Padding="16,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Realtor.ClickDayHint}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CalendarSelectedDay}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="{DynamicResource Realtor.ClickDayHint}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CalendarDayHasAppts}" Value="True">
                                                        <Setter Property="Text" Value="{Binding CalendarSelectedDateLabel}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Кнопка блокировки дня -->
                                    <Button Grid.Column="1"
                                            Content="{Binding CalendarBlockLabel}"
                                            Command="{Binding ToggleBlockDayCommand}"
                                            Padding="10,4" FontSize="11"
                                            Margin="8,0,0,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="Background" Value="#FF8F00"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CalendarHasDaySelected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelectedDayBlocked}" Value="True">
                                                        <Setter Property="Background" Value="#7CB342"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                                <!-- Ошибка блокировки -->
                                <TextBlock Text="{Binding CalendarBlockError}"
                                           FontSize="11" Foreground="{DynamicResource ErrorBrush}"
                                           Margin="0,4,0,4" TextWrapping="Wrap"
                                           Visibility="{Binding CalendarBlockError, Converter={StaticResource BoolToVisibility}}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                                    <ItemsControl ItemsSource="{Binding CalendarDayAppointments}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CardBrush}"
                                                        CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Time}"
                                                                   FontSize="13" FontWeight="Bold"
                                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ClientName}" FontSize="12"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding PropertyTitle}" FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="2" Background="{Binding StatusColor}"
                                                                CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Text="{DynamicResource Realtor.NoApptDay}"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding CalendarDayHasAppts}" Value="False"/>
                                                        <Condition Binding="{Binding CalendarSelectedDateLabel}" Value=""/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</UserControl>



