<UserControl x:Class="MSM.Views.RealtorProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="700" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>
            <Grid Margin="16,0">
                <Button Content="{DynamicResource Common.Back}" Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left" Background="Transparent"
                        Foreground="{DynamicResource AccentBrush}" BorderThickness="0" FontSize="14"/>
                <TextBlock Text="{DynamicResource RealtorProfile.Title}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Grid>
        </Border>

        <!-- Загрузка -->
        <TextBlock Grid.Row="1" Text="{DynamicResource Common.Loading}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
            <StackPanel Margin="24,20">

                <!-- Карточка риелтора -->
                <Border Background="{DynamicResource CardBrush}" CornerRadius="12"
                        Padding="24" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Аватар -->
                        <Border Grid.Column="0" Width="100" Height="100"
                                CornerRadius="50" ClipToBounds="True"
                                HorizontalAlignment="Left" VerticalAlignment="Top">
                            <!-- Фото если есть -->
                            <Image Source="{Binding AvatarImage}" Stretch="UniformToFill"
                                   Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}}"/>
                        </Border>
                        <!-- Заглушка аватара -->
                        <Border Grid.Column="0" Width="100" Height="100"
                                CornerRadius="50" Background="{DynamicResource PrimaryBrush}"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                            <TextBlock Text="👤" FontSize="44"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Инфо -->
                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <TextBlock Text="{Binding RealtorName}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>

                            <!-- Рейтинг -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="{Binding StatRatingStars}" FontSize="18"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock FontSize="14" Margin="8,2,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="{Binding StatRating, StringFormat='{}{0:F1}'}"/>
                                    <Run Text="из 5"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Контакты -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="📞 " FontSize="13"/>
                                <TextBlock Text="{Binding RealtorPhone}" FontSize="13"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="✉ " FontSize="13"/>
                                <TextBlock Text="{Binding RealtorEmail}" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Описание -->
                            <TextBlock Text="{Binding RealtorDescription}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Статистика -->
                <UniformGrid Columns="3" Margin="0,0,0,20">
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Padding="20" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource RealtorProfile.TotalProps}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding StatProperties}" FontSize="32" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Padding="20" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource RealtorProfile.Sold}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding StatSold}" FontSize="32" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource RealtorProfile.Rating}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding StatRating, StringFormat='{}{0:F1} ★'}"
                                       FontSize="32" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Отзывы -->
                <TextBlock Text="{DynamicResource RealtorProfile.Reviews}" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- Нет отзывов -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="20"
                        Visibility="{Binding NoReviews, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{DynamicResource RealtorProfile.NoReviews}"
                               HorizontalAlignment="Center" FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>

                <!-- Список отзывов -->
                <ItemsControl ItemsSource="{Binding Reviews}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                    Padding="16,12" Margin="0,0,0,8">
                                <Border.Effect>
                                    <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="4" ShadowDepth="1" Opacity="0.07"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Author}" FontWeight="SemiBold"
                                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Stars}" FontSize="14"
                                                       Foreground="{DynamicResource PrimaryBrush}" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Date}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Comment}" FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,6,0,0"
                                               Visibility="{Binding Comment, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
