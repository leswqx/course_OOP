<UserControl x:Class="MSM.Views.RealtorProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="700" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>
            <Grid Margin="16,0">
                <Button Content="{DynamicResource Common.Back}" Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left" Background="Transparent"
                        Foreground="{DynamicResource AccentBrush}" BorderThickness="0" FontSize="14"/>
                <TextBlock Text="{DynamicResource RealtorProfile.Title}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Grid>
        </Border>

        <!-- Загрузка -->
        <TextBlock Grid.Row="1" Text="{DynamicResource Common.Loading}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Ошибка (например, риелтор не найден) -->
        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="15" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                   Margin="20,0"
                   Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
            <StackPanel Margin="24,20">

                <!-- Карточка риелтора -->
                <Border Background="{DynamicResource CardBrush}" CornerRadius="12"
                        Padding="24" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Аватар -->
                        <Border Grid.Column="0" Width="100" Height="100"
                                CornerRadius="50" ClipToBounds="True"
                                HorizontalAlignment="Left" VerticalAlignment="Top">
                            <!-- Фото если есть -->
                            <Image Source="{Binding AvatarImage}" Stretch="UniformToFill"
                                   Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}}"/>
                        </Border>
                        <!-- Заглушка аватара -->
                        <Border Grid.Column="0" Width="100" Height="100"
                                CornerRadius="50" Background="{DynamicResource PrimaryBrush}"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                            <Path Width="44" Height="44" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Fill="White"
                                  Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                        </Border>

                        <!-- Инфо -->
                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <TextBlock Text="{Binding RealtorName}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>

                            <!-- Рейтинг -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="{Binding StatFilledStars}" FontSize="18"
                                           Foreground="#F4B942"/>
                                <TextBlock Text="{Binding StatEmptyStars}" FontSize="18"
                                           Foreground="#D0D0D0"/>
                                <TextBlock FontSize="14" Margin="8,2,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="{Binding StatRating, StringFormat='{}{0:F1}'}"/>
                                    <Run Text="{DynamicResource Common.OutOf5}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Контакты -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Path Width="13" Height="13" Stretch="Uniform" Margin="0,0,5,0" VerticalAlignment="Center"
                                      Fill="{DynamicResource TextSecondaryBrush}"
                                      Data="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z"/>
                                <TextBlock Text="{Binding RealtorPhone}" FontSize="13"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Path Width="13" Height="13" Stretch="Uniform" Margin="0,0,5,0" VerticalAlignment="Center"
                                      Fill="{DynamicResource TextSecondaryBrush}"
                                      Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"/>
                                <TextBlock Text="{Binding RealtorEmail}" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Описание -->
                            <TextBlock Text="{Binding RealtorDescription}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Статистика -->
                <UniformGrid Columns="3" Margin="0,0,0,20">

                    <!-- Всего объектов -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Margin="0,0,8,0" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#1565C0"/>
                            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="16,10,16,14">
                                <TextBlock Text="{DynamicResource RealtorProfile.TotalProps}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding StatProperties}" FontSize="32" FontWeight="Bold"
                                           Foreground="#1565C0"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Продано -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                            Margin="0,0,8,0" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#00897B"/>
                            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="16,10,16,14">
                                <TextBlock Text="{DynamicResource RealtorProfile.Sold}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding StatSold}" FontSize="32" FontWeight="Bold"
                                           Foreground="#00897B"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Рейтинг -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="6" ShadowDepth="1" Opacity="0.10"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#F4B942"/>
                            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="16,10,16,14">
                                <TextBlock Text="{DynamicResource RealtorProfile.Rating}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding StatRating, StringFormat='{}{0:F1}'}"
                                               FontSize="32" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" ★" FontSize="28" FontWeight="Bold"
                                               Foreground="#F4B942"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                </UniformGrid>

                <!-- Отзывы -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource RealtorProfile.Reviews}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Review.SortLabel}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource Review.SortDateDesc}"
                                Command="{Binding SortDateDescCommand}"
                                Height="28" Padding="10,0" FontSize="11" Margin="0,0,4,0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSortDateDesc}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource Review.SortDateAsc}"
                                Command="{Binding SortDateAscCommand}"
                                Height="28" Padding="10,0" FontSize="11" Margin="0,0,4,0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSortDateAsc}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource Review.SortRatingDesc}"
                                Command="{Binding SortRatingDescCommand}"
                                Height="28" Padding="10,0" FontSize="11" Margin="0,0,4,0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSortRatingDesc}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource Review.SortRatingAsc}"
                                Command="{Binding SortRatingAscCommand}"
                                Height="28" Padding="10,0" FontSize="11" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSortRatingAsc}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Нет отзывов -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="20"
                        Visibility="{Binding NoReviews, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{DynamicResource RealtorProfile.NoReviews}"
                               HorizontalAlignment="Center" FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>

                <!-- Список отзывов -->
                <ItemsControl ItemsSource="{Binding Reviews}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                    Padding="16,12" Margin="0,0,0,8">
                                <Border.Effect>
                                    <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="4" ShadowDepth="1" Opacity="0.07"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Author}" FontWeight="SemiBold"
                                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding FilledStars}" FontSize="14"
                                                       Foreground="#F4B942" Margin="10,0,0,0"/>
                                            <TextBlock Text="{Binding EmptyStars}" FontSize="14"
                                                       Foreground="#D0D0D0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Date}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Comment}" FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,6,0,0"
                                               Visibility="{Binding Comment, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Показать ещё отзывы -->
                <Button Command="{Binding ShowMoreReviewsCommand}"
                        Visibility="{Binding HasMoreReviews, Converter={StaticResource BoolToVisibility}}"
                        HorizontalAlignment="Center" Margin="0,12,0,4"
                        Height="36" Padding="28,0" FontSize="13" Cursor="Hand"
                        Background="Transparent"
                        Foreground="{DynamicResource PrimaryBrush}"
                        BorderBrush="{DynamicResource PrimaryBrush}"
                        BorderThickness="1">
                    <TextBlock>
                        <Run Text="{DynamicResource Review.ShowMore}"/>
                    </TextBlock>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

