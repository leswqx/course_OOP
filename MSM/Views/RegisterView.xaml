<UserControl x:Class="MSM.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:MSM.Helpers"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="560" d:DesignWidth="380">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
                <TextBlock Text="🏠" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource App.Title}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,4"/>
                <TextBlock Text="{DynamicResource Register.Subtitle}"
                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Форма -->
            <StackPanel Grid.Row="1">

                <TextBlock Text="{DynamicResource Register.FullName}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                         Height="36" Padding="10,0" FontSize="13" Margin="0,0,0,12"/>

                <TextBlock Text="{DynamicResource Login.LoginLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         Height="36" Padding="10,0" FontSize="13" Margin="0,0,0,12"/>

                <TextBlock Text="{DynamicResource Register.Email}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Height="36" Padding="10,0" FontSize="13" Margin="0,0,0,12"/>

                <TextBlock Text="{DynamicResource Register.Phone}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Height="36" Padding="10,0" FontSize="13" Margin="0,0,0,12"/>

                <TextBlock Text="{DynamicResource Login.PasswordLabel}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                             helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Padding="10,0" FontSize="13" Margin="0,0,0,12"/>

                <TextBlock Text="{DynamicResource Register.ConfirmPassword}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                             helpers:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Padding="10,0" FontSize="13" Margin="0,0,0,8"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource ErrorBrush}"
                           FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}"/>

                <Button Content="{DynamicResource Register.Submit}"
                        Command="{Binding RegisterCommand}"
                        Height="40" FontSize="14" Margin="0,0,0,8"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White" BorderThickness="0"/>

                <Button Content="{DynamicResource Common.Back}"
                        Command="{Binding GoBackCommand}"
                        Height="36" FontSize="13"
                        Background="Transparent"
                        Foreground="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
