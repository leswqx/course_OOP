<UserControl x:Class="MSM.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:MSM.Helpers"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Margin="0,70,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="420"
                    Margin="0,20,0,20"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="18"
                    Padding="44,36">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.13"
                                      BlurRadius="36" ShadowDepth="6"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Название -->
                    <TextBlock Text="{DynamicResource App.Title}"
                               FontSize="19" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,4"/>

                    <!-- Подзаголовок -->
                    <TextBlock Text="{DynamicResource Register.Subtitle}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,24"/>

                    <!-- Полное имя -->
                    <TextBlock Text="{DynamicResource Register.FullName}"
                               Margin="0,0,0,5"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                             Height="42" Padding="12,0,0,0" FontSize="14" Margin="0,0,0,14"/>

                    <!-- Логин -->
                    <TextBlock Text="{DynamicResource Login.LoginLabel}"
                               Margin="0,0,0,5"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                             Height="42" Padding="12,0,0,0" FontSize="14" Margin="0,0,0,14"/>

                    <!-- E-mail -->
                    <TextBlock Text="{DynamicResource Register.Email}"
                               Margin="0,0,0,5"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Height="42" Padding="12,0,0,0" FontSize="14" Margin="0,0,0,14"/>

                    <!-- Телефон -->
                    <TextBlock Text="{DynamicResource Register.Phone}"
                               Margin="0,0,0,5"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Height="42" Padding="12,0,0,0" FontSize="14" Margin="0,0,0,14"/>

                    <!-- Пароль -->
                    <TextBlock Text="{DynamicResource Login.PasswordLabel}"
                               Margin="0,0,0,5"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                 helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="42" Padding="12,0,0,0" FontSize="14" Margin="0,0,0,14"/>

                    <!-- Подтверждение пароля -->
                    <TextBlock Text="{DynamicResource Register.ConfirmPassword}"
                               Margin="0,0,0,5"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <PasswordBox helpers:PasswordBoxHelper.BindPassword="True"
                                 helpers:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="42" Padding="12,0,0,0" FontSize="14" Margin="0,0,0,8"/>

                    <!-- Ошибка -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource ErrorBrush}"
                               Margin="0,0,0,14"
                               TextWrapping="Wrap"
                               MinHeight="18"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Зарегистрироваться -->
                    <Button Content="{DynamicResource Register.Submit}"
                            Command="{Binding RegisterCommand}"
                            Height="42" FontSize="16" Margin="0,0,0,10"
                            Background="{DynamicResource PrimaryBrush}"
                            Foreground="White"
                            BorderThickness="0"/>

                    <!-- Войти -->
                    <Button Content="{DynamicResource Login.SignIn}"
                            Command="{Binding GoBackCommand}"
                            Height="40" FontSize="14"
                            Background="Transparent"
                            Foreground="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
